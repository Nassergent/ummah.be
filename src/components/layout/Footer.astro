---
import { fetchSettings } from '../../lib/sanity';

const settings = await fetchSettings();
const year = new Date().getFullYear();
const orgNaam = settings?.organisatieNaam || 'Ummah.be Waqf';
const kbo = settings?.kboNummer;
const adres = settings?.adres;
const iban = settings?.iban;
const email = settings?.email || 'salam@ummah.be';
---

<footer class="border-t border-border" style="background: var(--color-capital-dark);">
  <div class="container py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <!-- Brand -->
      <div>
        <h3 class="text-xl text-white mb-4">{orgNaam}</h3>
        <p class="text-sm text-white/60 leading-relaxed">
          Kapitaal is heilig. Opbrengsten dienen moslims. Voor altijd.
        </p>
      </div>

      <!-- Ontdek -->
      <div>
        <h4 class="text-sm font-semibold text-white/80 uppercase tracking-wider mb-4">Ontdek</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/wat-is-een-waqf" class="text-white/60 hover:text-white no-underline transition-colors">Wat is een Waqf?</a></li>
          <li><a href="/over-ons" class="text-white/60 hover:text-white no-underline transition-colors">Over Ons</a></li>
          <li><a href="/nalatenschap" class="text-white/60 hover:text-white no-underline transition-colors">Nalatenschap</a></li>
          <li><a href="/veelgestelde-vragen" class="text-white/60 hover:text-white no-underline transition-colors">Veelgestelde vragen</a></li>
          <li><a href="/woordenlijst" class="text-white/60 hover:text-white no-underline transition-colors">Woordenlijst</a></li>
        </ul>
      </div>

      <!-- Details -->
      <div>
        <h4 class="text-sm font-semibold text-white/80 uppercase tracking-wider mb-4">Details</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/steun-ons" class="text-white/60 hover:text-white no-underline transition-colors">Steun Ons</a></li>
          <li><a href="/governance" class="text-white/60 hover:text-white no-underline transition-colors">Toezicht &amp; Bestuur</a></li>
          <li><a href="/transparantie" class="text-white/60 hover:text-white no-underline transition-colors">Transparantie</a></li>
          <li><a href="/contact" class="text-white/60 hover:text-white no-underline transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Juridisch -->
      <div>
        <h4 class="text-sm font-semibold text-white/80 uppercase tracking-wider mb-4">Juridisch</h4>
        <div class="text-sm text-white/60 leading-relaxed space-y-1">
          <p>{orgNaam}</p>
          {adres && <p>{adres}</p>}
          {kbo && <p>KBO: {kbo}</p>}
          {iban && <p class="pt-2 font-mono text-xs">IBAN: {iban}</p>}
          <p class="pt-2"><a href={`mailto:${email}`} class="text-white/60 hover:text-white no-underline">{email}</a></p>
        </div>
      </div>
    </div>

    <div class="border-t border-white/10 mt-12 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-white/30">&copy; {year} {orgNaam} — Een Belgische waqf instelling</p>
      <a
        href="https://ummah-be.sanity.studio/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-xs text-white/30 hover:text-white/60 no-underline transition-colors"
        aria-label="Admin dashboard (Sanity Studio)"
      >
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        Admin
      </a>
    </div>
  </div>
</footer>
