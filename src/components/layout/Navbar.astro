---
const currentPath = Astro.url.pathname;
const links = [
  { href: '/', label: 'Home' },
  { href: '/wat-is-een-waqf', label: 'Wat is een Waqf?' },
  { href: '/wat-we-doen', label: 'Wat we doen' },
  { href: '/steun-ons', label: 'Steun Ons' },
  { href: '/nalatenschap', label: 'Nalatenschap' },
  { href: '/contact', label: 'Contact' },
];
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-border" style="box-shadow: 0 1px 8px rgba(45,52,54,0); transition: box-shadow 0.3s cubic-bezier(0.23, 1, 0.32, 1);" role="navigation" aria-label="Hoofdnavigatie">
  <div class="container flex justify-between items-center h-20">
    <a href="/" class="flex items-center gap-3 no-underline">
      <span class="font-heading text-2xl font-bold" style="color: var(--color-capital);">Ummah.be</span>
      <span class="badge-sacred text-[10px]">WAQF</span>
    </a>

    <!-- Desktop Menu -->
    <div class="hidden lg:flex items-center gap-1">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            'px-4 py-2 text-sm font-medium no-underline rounded transition-colors',
            currentPath === link.href
              ? 'font-bold'
              : 'hover:opacity-70',
          ]}
          style={currentPath === link.href ? 'color: var(--color-capital);' : 'color: var(--color-text);'}
          aria-current={currentPath === link.href ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
      <a href="/steun-ons" class="btn btn-capital ml-4 text-xs">Draag Bij</a>
    </div>

    <!-- Mobile Menu Toggle -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden w-11 h-11 flex items-center justify-center rounded"
      aria-label="Menu openen"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg id="menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
      </svg>
      <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="lg:hidden bg-white border-t border-border overflow-hidden"
    style="max-height: 0; opacity: 0; transition: max-height 0.3s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.2s cubic-bezier(0.16, 1, 0.3, 1);"
    aria-hidden="true"
  >
    <div class="container py-6 flex flex-col gap-2">
      {links.map((link) => (
        <a
          href={link.href}
          class="py-3 text-lg font-heading font-bold no-underline rounded px-2"
          style="color: var(--color-text);"
        >
          {link.label}
        </a>
      ))}
      <a href="/steun-ons" class="btn btn-capital text-center mt-4">Draag Bij aan Kapitaal</a>
    </div>
  </div>
</nav>

<div class="h-20" aria-hidden="true" />

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');
  let open = false;

  function closeMenu() {
    if (!open) return;
    open = false;
    menuIcon?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
    btn!.setAttribute('aria-expanded', 'false');
    btn!.setAttribute('aria-label', 'Menu openen');
    menu?.setAttribute('aria-hidden', 'true');
    menu!.style.maxHeight = '0';
    menu!.style.opacity = '0';
    btn!.focus();
  }

  function openMenu() {
    open = true;
    menuIcon?.classList.add('hidden');
    closeIcon?.classList.remove('hidden');
    btn!.setAttribute('aria-expanded', 'true');
    btn!.setAttribute('aria-label', 'Menu sluiten');
    menu?.setAttribute('aria-hidden', 'false');
    menu!.style.maxHeight = menu!.scrollHeight + 'px';
    menu!.style.opacity = '1';
  }

  btn?.addEventListener('click', () => {
    if (open) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && open) {
      closeMenu();
    }
  });

  // Navbar shadow on scroll
  const nav = document.getElementById('main-nav');
  if (nav) {
    const onScroll = () => {
      nav.style.boxShadow = window.scrollY > 10
        ? '0 1px 8px rgba(45,52,54,0.08)'
        : '0 1px 8px rgba(45,52,54,0)';
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
