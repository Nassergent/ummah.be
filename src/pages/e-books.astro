---
import Layout from '../layouts/Layout.astro';
import { fetchEbooks } from '../lib/sanity';

const sanityEbooks = await fetchEbooks();

// Fallback naar hardcoded data als Sanity leeg is
const fallbackEbooks = [
  { titel: "Wat is Islam?", categorie: "Nieuw bij Islam", beschrijving: "Een heldere introductie voor iedereen die meer wilt weten over de islam. Geschreven in begrijpelijk Nederlands.", aantalPaginas: "32 pagina's", omslagKleur: "bg-clarity", pdfUrl: null, downloadCount: 0 },
  { titel: "De Eerste Stappen", categorie: "Nieuwe Moslims", beschrijving: "Een praktische gids voor wie de shahada heeft uitgesproken. Van gebed tot gemeenschap.", aantalPaginas: "48 pagina's", omslagKleur: "bg-capital", pdfUrl: null, downloadCount: 0 },
  { titel: "Waqf: Een Eeuwige Gift", categorie: "Islamitische Financiën", beschrijving: "Alles over de waqf-traditie — van de Profeet ﷺ tot vandaag.", aantalPaginas: "24 pagina's", omslagKleur: "bg-gold", pdfUrl: null, downloadCount: 0 },
  { titel: "Ramadan Handboek", categorie: "Voor het Gezin", beschrijving: "Praktische tips, dua's en uitleg over de vastenmaand. Voor het hele gezin.", aantalPaginas: "40 pagina's", omslagKleur: "bg-growth", pdfUrl: null, downloadCount: 0 },
];

const ebooks = sanityEbooks.length > 0 ? sanityEbooks : fallbackEbooks;
const totalDownloads = ebooks.reduce((sum: number, e: any) => sum + (e.downloadCount || 0), 0);

// Dynamische categorieën uit data + "Alle"
const uniqueCategories = [...new Set(ebooks.map((e: any) => e.categorie))];
const categories = ["Alle", ...uniqueCategories];
---

<Layout title="E-books — Ummah.be Waqf" description="Gratis islamitische e-books als sadaqah jariyah. Download zonder voorwaarden.">

  <!-- HERO -->
  <section class="section" style="background: var(--color-peace);">
    <div class="container text-center max-w-[700px]">
      <h1 class="mb-4 fade-up text-capital">E-books</h1>
      <p class="text-lg md:text-xl text-clarity font-semibold fade-up delay-1">Gratis kennis als sadaqah jariyah — voor iedereen</p>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section-sm">
    <div class="container-narrow">
      <div class="card card-static fade-up">
        <blockquote class="blockquote-gold pl-4 mb-4 font-heading italic text-lg">
          "Wanneer een mens sterft, stoppen al zijn daden behalve drie: doorlopende liefdadigheid, kennis waar anderen profijt van hebben, en een vroom kind dat voor hem bidt."
        </blockquote>
        <p class="text-sm text-text-light mb-4">— Sahih Muslim 1631</p>
        <p class="text-base text-text">
          Deze e-books zijn gratis. Geen email vereist. Geen voorwaarden. Kennis delen is onze eerste daad van sadaqah jariyah.
        </p>
      </div>
    </div>
  </section>

  <!-- E-BOOKS SECTION -->
  <section class="section" style="background: white;">
    <div class="container">

      <!-- Download counter -->
      <div class="text-center mb-8 fade-up">
        <p class="text-sm font-semibold text-text-light">
          <span class="text-capital font-bold text-lg">{totalDownloads}</span> e-books gedownload
        </p>
      </div>

      <!-- Category filter -->
      <div class="flex gap-2 mb-12 justify-center flex-wrap fade-up delay-1" role="tablist" aria-label="E-book categorieën">
        {categories.map((cat, i) => (
          <button
            class="filter-btn btn text-xs"
            data-category={cat}
            role="tab"
            aria-selected={i === 0 ? "true" : "false"}
            style={i === 0 ? "background: var(--color-capital); color: var(--color-peace);" : "background: var(--color-border); color: var(--color-text);"}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- E-books grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6" id="ebooks-grid">
        {ebooks.map((book, i) => (
          <div class={`card fade-up delay-${i + 1} ebook-card`} data-category={book.categorie}>
            <!-- Book cover placeholder -->
            <div class={`${book.omslagKleur} rounded-lg mb-4 flex items-center justify-center p-6`} style="min-height: 180px;">
              <p class="font-heading font-bold text-lg text-center text-white leading-tight">{book.titel}</p>
            </div>

            <!-- Category badge -->
            <span class="badge badge-sacred mb-3">{book.categorie}</span>

            <!-- Title -->
            <h3 class="text-lg mb-2">{book.titel}</h3>

            <!-- Description -->
            <p class="text-sm text-text-light mb-3 text-clamp-3">{book.beschrijving}</p>

            <!-- Page count -->
            <p class="text-xs text-text-light mb-4">{book.aantalPaginas}</p>

            <!-- Download button -->
            {book.pdfUrl ? (
              <button class="btn btn-capital text-center w-full block" data-download-url={book.pdfUrl} data-ebook-id={book.titel}>Download PDF</button>
            ) : (
              <span class="btn text-center w-full block" style="background: var(--color-border); color: var(--color-text-light); cursor: default;">Binnenkort beschikbaar</span>
            )}
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- CALL FOR SUGGESTIONS -->
  <section class="section-sm">
    <div class="container text-center max-w-[600px] fade-up">
      <h2 class="mb-4">Mis je een onderwerp?</h2>
      <p class="text-lg text-text-light mb-6">Laat het ons weten. We schrijven graag nieuwe e-books op basis van jullie vragen.</p>
      <a href="/contact" class="btn btn-outline">Stel een onderwerp voor</a>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-lg" style="background: var(--color-capital-dark);">
    <div class="container text-center max-w-[700px]">
      <p class="display-quote text-white/90 mb-8 fade-up" style="font-style: italic;">
        Kennis delen is sadaqah jariyah
      </p>
      <p class="text-white/70 text-lg mb-10 fade-up delay-1">Steun ons werk en help ons meer kennis te verspreiden.</p>
      <div class="flex gap-4 justify-center flex-wrap fade-up delay-2">
        <a href="/de-bouwers" class="btn btn-gold">Word Bouwer</a>
        <a href="/wat-we-doen" class="btn btn-outline-white">Bekijk al onze projecten</a>
      </div>
    </div>
  </section>

</Layout>

<script>
  // Download tracking
  document.querySelectorAll('[data-download-url]').forEach(btn => {
    btn.addEventListener('click', () => {
      const url = (btn as HTMLElement).dataset.downloadUrl;
      const id = (btn as HTMLElement).dataset.ebookId;
      window.open(url, '_blank');
      fetch('/api/track-download', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ebookId: id})
      }).catch(() => {});
    });
  });

  // Category filter functionality
  (() => {
    const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('.ebook-card');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const category = btn.dataset.category;

        // Update button states
        filterBtns.forEach(b => {
          b.setAttribute('aria-selected', 'false');
          b.style.background = 'var(--color-border)';
          b.style.color = 'var(--color-text)';
        });
        btn.setAttribute('aria-selected', 'true');
        btn.style.background = 'var(--color-capital)';
        btn.style.color = 'var(--color-peace)';

        // Filter cards
        cards.forEach(card => {
          if (category === 'Alle' || card.dataset.category === category) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  })();
</script>
