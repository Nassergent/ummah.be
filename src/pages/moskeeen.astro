---
import Layout from '../layouts/Layout.astro';
import { fetchMosques } from '../lib/sanity';

const sanityMosques = await fetchMosques();

const fallbackMosques = [
  { naam: "Moskee El Albani", stad: "Gent, België", status: "Live", beschrijving: "De eerste moskee op het Ummah.be platform. Volledig operationeel met gebedstijden, donaties en evenementen.", websiteUrl: "https://moskee-el-albani-gent.vercel.app" },
  { naam: "Moskee El Fath", stad: "Gent, België", status: "Live", beschrijving: "Tweede moskee in de fleet. Charcoal Sage thema met volledige gebedstijden en donatie-integratie.", websiteUrl: "https://moskee-el-fath-gent.vercel.app" },
  { naam: "Moskee OKBA IBN NAFI", stad: "Warandestraat 39, 9000 Gent", status: "Bouwfase", beschrijving: "Nieuwste moskee in de fleet. Charcoal Sage thema met live gebedstijden en smart prayer alerts.", websiteUrl: "https://moskee-okba-ibn-nafi.vercel.app" },
];

const mosques = sanityMosques.length > 0 ? sanityMosques : fallbackMosques;
---

<Layout title="Moskeeën — Ummah.be Waqf" description="Moskeeën die gebruik maken van het Ummah.be platform.">

  <!-- HERO -->
  <section class="section" style="background: var(--color-capital);">
    <div class="container text-center">
      <h1 class="text-white mb-4 fade-up">Partner Moskeeën</h1>
      <p class="text-white/70 text-lg max-w-[700px] mx-auto fade-up delay-1">
        Ummah.be Waqf werkt samen met Belgische moskeeën via een zuster-project:
        een gedeeld digitaal platform dat moskeeën voorziet van een website,
        gebedstijden en donatie-systeem — zonder commerciële winst.
      </p>
      <p class="text-white/70 text-sm mt-4 fade-up delay-2">
        Deze moskeeën zijn <strong>geen onderdeel van het waqf-kapitaal</strong>. Het zijn autonome VZW's die gebruikmaken van onze open infrastructuur.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {mosques.map((mosque: any, i: number) => {
          const badgeClass = mosque.status === 'Live' ? 'badge-sacred' : mosque.status === 'Bouwfase' ? 'badge-growth' : 'badge-zakat';
          return (
            <div class="card card-capital fade-up" style={`animation-delay: ${i * 0.06}s;`}>
              <div class={`${badgeClass} mb-4`}>{mosque.status}</div>
              <h3 class="text-xl mb-2">{mosque.naam}</h3>
              <p class="text-sm mb-4 text-text-light">{mosque.stad}</p>
              {mosque.beschrijving && (
                <p class="text-sm mb-4 text-text-light">{mosque.beschrijving}</p>
              )}
              {mosque.websiteUrl && (
                <a href={mosque.websiteUrl} target="_blank" rel="noopener noreferrer" class="text-sm font-semibold no-underline link-arrow text-capital">
                  Bezoek website
                </a>
              )}
            </div>
          );
        })}
      </div>

      <!-- Meer moskeeën -->
      <div class="text-center mt-16 fade-up">
        <div class="card max-w-[500px] mx-auto text-center">
          <h3 class="text-xl mb-3">Wil jouw moskee ook een website?</h3>
          <p class="text-sm mb-6 text-text-light">
            Wij bieden moskeeën een compleet digitaal platform: website, gebedstijden,
            donaties, evenementen en meer. Alles beheerd via een eenvoudig CMS.
          </p>
          <a href="#aanvraag" class="btn btn-capital text-xs">Vraag nu aan</a>
        </div>
      </div>
    </div>
  </section>

  <!-- AANVRAAG FORMULIER -->
  <section id="aanvraag" class="section" style="background: var(--color-surface);">
    <div class="container max-w-[640px]">
      <div class="text-center mb-12 fade-up">
        <h2 class="mb-4">Website aanvragen voor uw moskee</h2>
        <p class="text-text-light">Vul het formulier in en wij nemen binnen 48 uur contact op.</p>
      </div>

      <form id="moskee-aanvraag-form" class="space-y-6 fade-up delay-1" novalidate>
        <div>
          <label for="moskee-naam" class="form-label">Moskee naam *</label>
          <input type="text" id="moskee-naam" name="moskee-naam" required class="input" placeholder="Bijv. Moskee Al-Ihsan" />
        </div>

        <div>
          <label for="stad" class="form-label">Stad *</label>
          <input type="text" id="stad" name="stad" required class="input" placeholder="Bijv. Gent" />
        </div>

        <div>
          <label for="contactpersoon" class="form-label">Contactpersoon naam *</label>
          <input type="text" id="contactpersoon" name="contactpersoon" required class="input" placeholder="Uw volledige naam" />
        </div>

        <div>
          <label for="email" class="form-label">E-mail *</label>
          <input type="email" id="email" name="email" required class="input" placeholder="uw@email.be" />
        </div>

        <div>
          <label for="telefoon" class="form-label">Telefoon</label>
          <input type="tel" id="telefoon" name="telefoon" class="input" placeholder="+32 ..." />
        </div>

        <div>
          <label for="bericht" class="form-label">Bericht</label>
          <textarea id="bericht" name="bericht" rows="4" class="input" placeholder="Vertel ons over uw moskee en wat u zoekt"></textarea>
        </div>

        <div class="flex items-start gap-3">
          <input type="checkbox" id="privacy" name="privacy" required class="checkbox-touch" />
          <label for="privacy" class="text-sm text-text-light">
            Ik ga akkoord met het <a href="/privacy" class="underline text-capital">privacybeleid</a> en geef toestemming om gecontacteerd te worden.
          </label>
        </div>

        <div id="form-message" class="text-sm font-medium" aria-live="polite"></div>

        <button type="submit" class="btn btn-capital w-full">Aanvraag versturen</button>
      </form>
    </div>
  </section>

  <script>
    const form = document.getElementById('moskee-aanvraag-form') as HTMLFormElement;
    const message = document.getElementById('form-message')!;

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      message.textContent = '';
      message.className = 'text-sm font-medium';

      // Validate required fields
      const naam = (form.querySelector('#moskee-naam') as HTMLInputElement).value.trim();
      const stad = (form.querySelector('#stad') as HTMLInputElement).value.trim();
      const contact = (form.querySelector('#contactpersoon') as HTMLInputElement).value.trim();
      const email = (form.querySelector('#email') as HTMLInputElement).value.trim();
      const privacy = (form.querySelector('#privacy') as HTMLInputElement).checked;

      if (!naam || !stad || !contact || !email) {
        message.textContent = 'Vul alle verplichte velden in.';
        message.style.color = 'var(--color-error, #e74c3c)';
        return;
      }

      if (!email.includes('@') || !email.includes('.')) {
        message.textContent = 'Vul een geldig e-mailadres in.';
        message.style.color = 'var(--color-error, #e74c3c)';
        return;
      }

      if (!privacy) {
        message.textContent = 'U moet akkoord gaan met het privacybeleid.';
        message.style.color = 'var(--color-error, #e74c3c)';
        return;
      }

      // Simulate submission
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Verzenden...';

      setTimeout(() => {
        form.reset();
        btn.disabled = false;
        btn.textContent = 'Aanvraag versturen';
        message.textContent = 'Bedankt! Uw aanvraag is ontvangen. Wij nemen binnen 48 uur contact op.';
        message.style.color = 'var(--color-capital)';
      }, 1500);
    });
  </script>

</Layout>
