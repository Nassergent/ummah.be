---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
---

<Layout title="Vending Machines — Ummah.be Waqf" description="Verdien 25% commissie op de omzet zonder aankoopkosten. Wij plaatsen en beheren een vending machine met ethisch gescreend assortiment in uw locatie.">

  <!-- HERO -->
  <section class="section-lg bg-capital relative overflow-hidden">
    <div class="container text-center max-w-[700px]">
      <h1 class="text-white mb-6 fade-up" style="font-size: clamp(32px, 5vw, 52px);">Verdien 25% commissie — zonder eigen aankoopkosten</h1>
      <p class="text-xl md:text-2xl mb-8 fade-up delay-1" style="color: rgba(255,255,255,0.85);">
        Plaats een vending machine met ethisch gescreend assortiment in jouw moskee, sportclub of zaak. Wij regelen alles.
      </p>
      <div class="fade-up delay-2">
        <a href="#aanvraag" class="btn btn-gold">Vraag een machine aan</a>
      </div>
    </div>
  </section>

  <Breadcrumbs items={[{ label: 'Wat we doen', href: '/wat-we-doen' }, { label: 'Vending Machines' }]} />

  <!-- HOE HET WERKT -->
  <section class="section" style="background: white;">
    <div class="container">
      <h2 class="text-center mb-4 fade-up">Hoe het werkt</h2>
      <p class="text-center text-lg mb-12 max-w-[700px] mx-auto fade-up delay-1 text-text-light">
        Van aanmelding tot maandelijkse inkomsten — in vier stappen.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="card card-static text-center fade-up delay-1 step-connector">
          <div class="step-number step-number-capital">1</div>
          <h3 class="text-lg mb-2">U meldt uw locatie aan</h3>
          <p class="text-sm text-text-light">Via het formulier hieronder</p>
        </div>
        <div class="card card-static text-center fade-up delay-2 step-connector">
          <div class="step-number step-number-capital">2</div>
          <h3 class="text-lg mb-2">Wij analyseren uw locatie</h3>
          <p class="text-sm text-text-light">Bezoekersaantal, bereikbaarheid, potentieel</p>
        </div>
        <div class="card card-static text-center fade-up delay-3 step-connector">
          <div class="step-number step-number-capital">3</div>
          <h3 class="text-lg mb-2">Wij plaatsen en beheren alles</h3>
          <p class="text-sm text-text-light">Stock, onderhoud, betalingen — minimale betrokkenheid van uw kant</p>
        </div>
        <div class="card card-static text-center fade-up delay-4 step-connector">
          <div class="step-number step-number-growth">4</div>
          <h3 class="text-lg mb-2">U ontvangt maandelijks 25%</h3>
          <p class="text-sm text-text-light">Transparant, elke maand op uw rekening</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WAT KRIJGT U -->
  <section class="section">
    <div class="container">
      <h2 class="text-center mb-4 fade-up">Wat krijgt u?</h2>
      <p class="text-center text-lg mb-12 max-w-[700px] mx-auto fade-up delay-1 text-text-light">
        Alles is inbegrepen.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-[900px] mx-auto">
        <div class="card card-static fade-up delay-1">
          <div class="flex items-start gap-4">
            <div class="shrink-0 mt-1">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="14" cy="14" r="14" fill="rgba(27,94,63,0.1)"/>
                <path d="M9 14.5L12.5 18L19 11" stroke="#1B5E3F" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <h3 class="text-base mb-1">Zonder aankoopkosten voor u</h3>
              <p class="text-sm text-text-light">Wij financieren de machine, installatie en eerste stock volledig (elektriciteitskosten voor uw rekening)</p>
            </div>
          </div>
        </div>
        <div class="card card-static fade-up delay-2">
          <div class="flex items-start gap-4">
            <div class="shrink-0 mt-1">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="14" cy="14" r="14" fill="rgba(27,94,63,0.1)"/>
                <path d="M9 14.5L12.5 18L19 11" stroke="#1B5E3F" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <h3 class="text-base mb-1">Minimale betrokkenheid van uw kant</h3>
              <p class="text-sm text-text-light">Wij beheren stock, onderhoud en technische problemen</p>
            </div>
          </div>
        </div>
        <div class="card card-static fade-up delay-3">
          <div class="flex items-start gap-4">
            <div class="shrink-0 mt-1">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="14" cy="14" r="14" fill="rgba(27,94,63,0.1)"/>
                <path d="M9 14.5L12.5 18L19 11" stroke="#1B5E3F" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <h3 class="text-base mb-1">Maandelijkse inkomsten</h3>
              <p class="text-sm text-text-light">25% van de omzet wordt elke maand op uw rekening gestort</p>
            </div>
          </div>
        </div>
        <div class="card card-static fade-up delay-1">
          <div class="flex items-start gap-4">
            <div class="shrink-0 mt-1">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="14" cy="14" r="14" fill="rgba(27,94,63,0.1)"/>
                <path d="M9 14.5L12.5 18L19 11" stroke="#1B5E3F" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <h3 class="text-base mb-1">Volledig beheerd systeem</h3>
              <p class="text-sm text-text-light">Van plaatsing tot bevoorrading — alles geregeld</p>
            </div>
          </div>
        </div>
        <div class="card card-static fade-up delay-2">
          <div class="flex items-start gap-4">
            <div class="shrink-0 mt-1">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="14" cy="14" r="14" fill="rgba(27,94,63,0.1)"/>
                <path d="M9 14.5L12.5 18L19 11" stroke="#1B5E3F" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <h3 class="text-base mb-1">Transparante rapportering</h3>
              <p class="text-sm text-text-light">U krijgt maandelijks een helder overzicht van de omzet</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- VOORBEELD INKOMSTEN -->
  <section class="section" style="background: white;">
    <div class="container max-w-[700px]">
      <h2 class="text-center mb-4 fade-up">Voorbeeld inkomsten</h2>
      <p class="text-center text-lg mb-10 max-w-[600px] mx-auto fade-up delay-1 text-text-light">
        Wat kunt u verwachten?
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
        <div class="card card-static text-center fade-up delay-1">
          <p class="text-xs font-semibold uppercase tracking-wider mb-2 text-text-light">Klein</p>
          <p class="text-sm mb-2 text-text-light">Wachtruimte, kleine winkel</p>
          <p class="font-heading font-bold text-2xl text-capital">€25 – €75</p>
          <p class="text-xs text-text-light mt-1">per maand</p>
        </div>
        <div class="card card-capital text-center fade-up delay-2">
          <p class="text-xs font-semibold uppercase tracking-wider mb-2 text-gold">Gemiddeld</p>
          <p class="text-sm mb-2 text-text-light">Garage, sportclub</p>
          <p class="font-heading font-bold text-2xl text-capital">€75 – €150</p>
          <p class="text-xs text-text-light mt-1">per maand</p>
        </div>
        <div class="card card-static text-center fade-up delay-3">
          <p class="text-xs font-semibold uppercase tracking-wider mb-2 text-text-light">Groot</p>
          <p class="text-sm mb-2 text-text-light">Moskee, drukke winkel</p>
          <p class="font-heading font-bold text-2xl text-capital">€150 – €250</p>
          <p class="text-xs text-text-light mt-1">per maand</p>
        </div>
      </div>
      <p class="text-xs text-text-light text-center fade-up delay-4">Geschatte commissie (25% van de omzet). Werkelijke resultaten variëren per locatie.</p>
    </div>
  </section>

  <!-- VOOR WIE IS DIT -->
  <section class="section">
    <div class="container">
      <h2 class="text-center mb-4 fade-up">Voor wie is dit?</h2>
      <p class="text-center text-lg mb-12 max-w-[700px] mx-auto fade-up delay-1 text-text-light">
        Voor elke locatie met dagelijkse bezoekers.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6 max-w-[1000px] mx-auto">
        <div class="card card-static text-center fade-up delay-1">
          <div class="circle-icon circle-icon-capital mx-auto mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2L15 8H9L12 2Z" fill="currentColor"/>
              <rect x="4" y="8" width="16" height="12" rx="1" fill="currentColor"/>
              <rect x="10" y="13" width="4" height="7" fill="#1B5E3F"/>
            </svg>
          </div>
          <h3 class="text-base mb-1">Moskeeën</h3>
          <p class="text-xs text-text-light">Dagelijks honderden bezoekers bij elk gebed</p>
        </div>
        <div class="card card-static text-center fade-up delay-2">
          <div class="circle-icon circle-icon-capital mx-auto mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="3" y="6" width="18" height="14" rx="2" fill="currentColor"/>
              <rect x="7" y="2" width="10" height="4" rx="1" fill="currentColor"/>
              <rect x="8" y="10" width="8" height="4" rx="1" fill="#1B5E3F"/>
            </svg>
          </div>
          <h3 class="text-base mb-1">Winkels</h3>
          <p class="text-xs text-text-light">Extra service voor klanten en personeel</p>
        </div>
        <div class="card card-static text-center fade-up delay-3">
          <div class="circle-icon circle-icon-capital mx-auto mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="2" y="8" width="20" height="12" rx="2" fill="currentColor"/>
              <rect x="6" y="4" width="12" height="4" rx="1" fill="currentColor"/>
              <circle cx="8" cy="17" r="2" fill="#1B5E3F"/>
              <circle cx="16" cy="17" r="2" fill="#1B5E3F"/>
            </svg>
          </div>
          <h3 class="text-base mb-1">Garages</h3>
          <p class="text-xs text-text-light">Wachtende klanten waarderen een snelle snack</p>
        </div>
        <div class="card card-static text-center fade-up delay-4">
          <div class="circle-icon circle-icon-capital mx-auto mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="12" cy="12" r="9" fill="currentColor"/>
              <path d="M8 14C8 14 9.5 17 12 17C14.5 17 16 14 16 14" stroke="#1B5E3F" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="9" cy="10" r="1" fill="#1B5E3F"/>
              <circle cx="15" cy="10" r="1" fill="#1B5E3F"/>
            </svg>
          </div>
          <h3 class="text-base mb-1">Sportclubs</h3>
          <p class="text-xs text-text-light">Sporters zoeken altijd verfrissing en energie</p>
        </div>
        <div class="card card-static text-center fade-up delay-1">
          <div class="circle-icon circle-icon-capital mx-auto mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="4" y="4" width="16" height="16" rx="2" fill="currentColor"/>
              <rect x="7" y="8" width="4" height="2" rx="0.5" fill="#1B5E3F"/>
              <rect x="7" y="12" width="10" height="2" rx="0.5" fill="#1B5E3F"/>
              <rect x="7" y="16" width="6" height="1" rx="0.5" fill="#1B5E3F"/>
            </svg>
          </div>
          <h3 class="text-base mb-1">Wachtruimtes</h3>
          <p class="text-xs text-text-light">Ideaal voor artsen, kantoren en overheidsgebouwen</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WAAROM DIT ANDERS IS -->
  <section class="section" style="background: white;">
    <div class="container max-w-[800px]">
      <h2 class="text-center mb-4 fade-up">Ons assortiment</h2>
      <p class="text-center text-lg mb-10 max-w-[700px] mx-auto fade-up delay-1 text-text-light">
        Bewust samengesteld, ethisch verantwoord.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="card card-static fade-up delay-2">
          <h3 class="text-lg mb-3">Ethisch gescreend</h3>
          <p class="text-sm text-text-light">Ons assortiment wordt ethisch gescreend. Producten met alcohol of niet-halal ingrediënten worden niet opgenomen. Geen gokgerelateerde merken.</p>
        </div>
        <div class="card card-static fade-up delay-3">
          <h3 class="text-lg mb-3">Kwaliteit gegarandeerd</h3>
          <p class="text-sm text-text-light">Populaire snacks, dranken en gezonde opties — zorgvuldig geselecteerd. Regelmatig ververst en aangevuld.</p>
        </div>
      </div>
      <div class="callout callout-green fade-up delay-4">
        <p class="text-sm font-semibold text-capital">Halal assortiment &middot; Ethisch gescreend &middot; Bewust samengesteld &middot; Geen alcohol</p>
      </div>
    </div>
  </section>

  <!-- BELANGRIJKE INFORMATIE -->
  <section class="section" style="background: white;">
    <div class="container max-w-[700px]">
      <div class="callout callout-gold fade-up">
        <h3 class="font-heading font-bold text-lg mb-4 text-capital-dark">Belangrijke informatie</h3>
        <ul class="text-sm text-text-light space-y-3 list-disc pl-5">
          <li>De genoemde bedragen zijn schattingen en niet gegarandeerd. Sommige locaties genereren minder dan €50/maand.</li>
          <li>Elektriciteitskosten voor de vending machine zijn voor rekening van de locatie-eigenaar.</li>
          <li>De samenwerking wordt geregeld via een plaatsingsovereenkomst. Vraag naar de voorwaarden.</li>
          <li>De ontvangen commissie kan belastbaar zijn. Raadpleeg uw boekhouder.</li>
          <li>Ummah.be is eigenaar van de machine. Bij beëindiging wordt de machine kosteloos verwijderd.</li>
          <li>Pilotperiode van 3 maanden. Evaluatie na de pilotperiode.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- AANVRAAGFORMULIER -->
  <section id="aanvraag" class="section">
    <div class="container max-w-[600px]">
      <div class="text-center mb-8">
        <h2 class="mb-4 fade-up">Vraag een machine aan</h2>
        <p class="text-text-light fade-up delay-1">
          Vul het formulier in — wij nemen binnen 48 uur contact op.
        </p>
        <p class="text-sm mt-4 fade-up delay-2">
          <span class="text-text-light">Liever direct contact?</span>
          <a href="mailto:salam@ummah.be" class="text-capital font-semibold no-underline hover:underline ml-1">salam@ummah.be</a>
        </p>
      </div>

      <form id="vending-form" class="card card-capital fade-up delay-2" novalidate>
        <div class="mb-6">
          <label for="naam" class="form-label">Naam</label>
          <input type="text" id="naam" name="naam" class="input" placeholder="Uw volledige naam" required />
        </div>

        <div class="mb-6">
          <label for="telefoon" class="form-label">Telefoon</label>
          <input type="tel" id="telefoon" name="telefoon" class="input" placeholder="+32 4XX XX XX XX" required />
        </div>

        <div class="mb-6">
          <label for="email" class="form-label">E-mail <span class="font-normal normal-case text-text-light">(optioneel)</span></label>
          <input type="email" id="email" name="email" class="input" placeholder="uw@email.be" />
        </div>

        <div class="mb-6">
          <label for="adres" class="form-label">Adres locatie</label>
          <input type="text" id="adres" name="adres" class="input" placeholder="Straat, nummer, postcode, gemeente" required />
        </div>

        <div class="mb-6">
          <label for="type-locatie" class="form-label">Type locatie</label>
          <select id="type-locatie" name="type-locatie" class="input" required>
            <option value="" disabled selected>Kies een type</option>
            <option value="moskee">Moskee</option>
            <option value="winkel">Winkel</option>
            <option value="garage">Garage</option>
            <option value="sportclub">Sportclub</option>
            <option value="wachtruimte">Wachtruimte</option>
            <option value="restaurant">Restaurant</option>
            <option value="anders">Anders</option>
          </select>
        </div>

        <div class="mb-6">
          <label for="bezoekers" class="form-label">Geschat aantal bezoekers per dag</label>
          <select id="bezoekers" name="bezoekers" class="input" required>
            <option value="" disabled selected>Kies een bereik</option>
            <option value="minder-dan-50">Minder dan 50</option>
            <option value="50-100">50 – 100</option>
            <option value="100-250">100 – 250</option>
            <option value="250+">250+</option>
          </select>
        </div>

        <div class="mb-6">
          <label for="opmerkingen" class="form-label">Opmerkingen <span class="font-normal normal-case text-text-light">(optioneel)</span></label>
          <textarea id="opmerkingen" name="opmerkingen" class="input" rows="3" placeholder="Bijkomende info over uw locatie"></textarea>
        </div>

        <div class="mb-8">
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" id="privacy" name="privacy" class="checkbox-touch mt-0.5" required />
            <span class="text-sm text-text-light">Ik ga akkoord met het <a href="/privacy" class="text-capital font-semibold no-underline hover:underline">privacybeleid</a></span>
          </label>
        </div>

        <button type="submit" class="btn btn-capital w-full text-center">Aanvraag verzenden</button>

        <div id="form-message" class="form-message mt-4" role="alert" aria-live="polite"></div>
      </form>
    </div>
  </section>

  <!-- VERTROUWEN -->
  <section class="section" style="background: white;">
    <div class="container max-w-[800px]">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
        <div class="card card-static fade-up delay-1">
          <div class="circle-icon circle-icon-capital mx-auto mb-4">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M5 10L9 14L15 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 class="text-base mb-1">Vrijblijvende aanvraag</h3>
          <p class="text-sm text-text-light">Vrijblijvende aanvraag — u beslist pas na ons voorstel</p>
        </div>
        <div class="card card-static fade-up delay-2">
          <div class="circle-icon circle-icon-capital mx-auto mb-4">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M5 10L9 14L15 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 class="text-base mb-1">Gratis plaatsing</h3>
          <p class="text-sm text-text-light">Geen kosten voor installatie, machine of bevoorrading</p>
        </div>
        <div class="card card-static fade-up delay-3">
          <div class="circle-icon circle-icon-capital mx-auto mb-4">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M5 10L9 14L15 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 class="text-base mb-1">Volledige transparantie</h3>
          <p class="text-sm text-text-light">Maandelijks rapport met alle omzetcijfers</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SUBTIEL: UMMAH.BE CONNECTIE -->
  <section class="section-sm" style="background: var(--color-peace);">
    <div class="container text-center max-w-[600px]">
      <p class="text-sm text-text-light fade-up">
        Dit project is een initiatief van <a href="/" class="text-capital font-semibold no-underline hover:underline">Ummah.be</a> — een Belgische gemeenschapsorganisatie. Een deel van de opbrengsten gaat naar educatie- en gemeenschapsprojecten.
      </p>
    </div>
  </section>

  <!-- CTA BOTTOM -->
  <section class="section-lg bg-capital-dark">
    <div class="container text-center max-w-[700px]">
      <p class="display-quote mb-8 fade-up" style="color: rgba(255,255,255,0.9); font-style: italic;">
        Uw locatie, onze expertise, gedeelde opbrengst.
      </p>
      <div class="fade-up delay-1">
        <a href="#aanvraag" class="btn btn-gold">Vraag nu aan</a>
      </div>
    </div>
  </section>

</Layout>

<script>
  (() => {
    const form = document.getElementById('vending-form') as HTMLFormElement;
    const message = document.getElementById('form-message') as HTMLElement;

    if (!form || !message) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const naam = (form.querySelector('#naam') as HTMLInputElement).value.trim();
      const telefoon = (form.querySelector('#telefoon') as HTMLInputElement).value.trim();
      const email = (form.querySelector('#email') as HTMLInputElement)?.value.trim() || '';
      const adres = (form.querySelector('#adres') as HTMLInputElement).value.trim();
      const locatieType = (form.querySelector('#type-locatie') as HTMLSelectElement).value;
      const bezoekers = (form.querySelector('#bezoekers') as HTMLSelectElement).value;
      const opmerkingen = (form.querySelector('#opmerkingen') as HTMLTextAreaElement)?.value.trim() || '';
      const privacy = (form.querySelector('#privacy') as HTMLInputElement).checked;

      // Validation
      if (!naam || !telefoon || !adres) {
        message.textContent = 'Vul alstublieft alle verplichte velden in.';
        message.className = 'form-message visible error';
        return;
      }

      if (!locatieType) {
        message.textContent = 'Selecteer een type locatie.';
        message.className = 'form-message visible error';
        return;
      }

      if (!bezoekers) {
        message.textContent = 'Selecteer het geschatte aantal bezoekers.';
        message.className = 'form-message visible error';
        return;
      }

      if (!privacy) {
        message.textContent = 'U moet akkoord gaan met het privacybeleid.';
        message.className = 'form-message visible error';
        return;
      }

      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      submitBtn.classList.add('loading');
      submitBtn.disabled = true;
      message.className = 'form-message';

      try {
        const res = await fetch('/api/vending-aanvraag', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ naam, telefoon, email, adres, locatieType, bezoekers, opmerkingen }),
        });
        const json = await res.json();

        if (!res.ok) {
          throw new Error(json.error || 'Er ging iets mis.');
        }

        form.reset();
        message.textContent = 'Bedankt! Wij nemen binnen 48 uur telefonisch contact op.';
        message.className = 'form-message visible success';
      } catch (err: any) {
        message.textContent = err.message || 'Er ging iets mis. Probeer later opnieuw.';
        message.className = 'form-message visible error';
      } finally {
        submitBtn.classList.remove('loading');
        submitBtn.disabled = false;
      }
    });
  })();
</script>
