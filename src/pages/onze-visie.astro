---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
---

<Layout title="Onze Visie — Het Sneeuwbalmodel | Ummah.be Waqf" description="Hoe we stap voor stap bouwen aan een waqf dat zichzelf draagt. Sadaqah jariyah door kennis, gemeenschap en duurzame inkomsten.">

  <!-- HERO -->
  <section class="section-lg bg-capital relative overflow-hidden">
    <div class="container text-center max-w-[700px]">
      <h1 class="text-white mb-6 fade-up" style="font-size: clamp(36px, 5.5vw, 56px);">Onze Visie</h1>
      <p class="text-xl md:text-2xl fade-up delay-1" style="color: rgba(255,255,255,0.8);">
        Hoe we een zelfvoorzienend waqf bouwen dat de Ummah voor altijd dient
      </p>
    </div>
  </section>

  <Breadcrumbs items={[{ label: 'Onze Visie' }]} />

  <!-- DE KERNGEDACHTE -->
  <section class="section">
    <div class="container-content">
      <h2 class="text-center mb-4 fade-up">Waarom zelfvoorzienend?</h2>
      <p class="text-lg mb-8 max-w-[700px] mx-auto text-center fade-up delay-1 text-text-light">
        De meeste goede doelen zijn afhankelijk van donaties. Wanneer de donaties stoppen, stopt het werk. Wij bouwen anders. Wij bouwen een waqf dat zichzelf draagt — zodat de hulp nooit stopt.
      </p>
      <div class="fade-up delay-2">
        <blockquote class="blockquote-gold pl-6 py-4 my-8">
          <p class="display-quote text-capital" style="font-size: clamp(22px, 3.5vw, 36px);">
            "Wij geven niet alleen. Wij bouwen iets dat GEEFT — voor altijd."
          </p>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- HET SNEEUWBALMODEL -->
  <section class="section" style="background: white;">
    <div class="container max-w-[800px]">
      <div class="text-center mb-4">
        <span class="badge badge-sacred mb-6 fade-up">Het Sneeuwbalmodel</span>
        <h2 class="mb-4 fade-up delay-1">Hoe een waqf groeit</h2>
        <p class="text-lg mb-12 max-w-[700px] mx-auto fade-up delay-2 text-text-light">
          Hoe we stap voor stap bouwen aan een waqf dat zichzelf draagt
        </p>
      </div>

      <!-- Fase 1 -->
      <div class="relative mb-2">
        <div class="card card-capital fade-up">
          <div class="flex items-start gap-5">
            <div class="step-number step-number-capital shrink-0" style="margin: 0;">1</div>
            <div class="flex-1">
              <h3 class="text-xl mb-3">Vandaag: sadaqah jariyah door kennis en dienstverlening</h3>
              <p class="text-text-light mb-3">
                Gratis websites voor moskee&euml;n. Gratis e-books. Gratis Korans. Dit is al op zichzelf sadaqah jariyah — kennis delen en de gemeenschap dienen.
              </p>
              <p class="text-text-light mb-4">
                Het waqf-model maakt het mogelijk om dit voor altijd vol te houden.
              </p>
              <span class="badge badge-sacred">Actief — al 3 moskee-websites live</span>
            </div>
          </div>
        </div>
        <!-- Connector -->
        <div class="flex justify-center">
          <div class="w-0.5 h-8 bg-capital-15"></div>
        </div>
      </div>

      <!-- Fase 2 -->
      <div class="relative mb-2">
        <div class="card card-capital fade-up delay-1">
          <div class="flex items-start gap-5">
            <div class="step-number step-number-capital shrink-0" style="margin: 0;">2</div>
            <div class="flex-1">
              <h3 class="text-xl mb-3">Binnenkort: samen bouwen aan het waqf</h3>
              <p class="text-text-light mb-3">
                De Bouwers: moslims die maandelijks bijdragen aan het waqf-kapitaal.
              </p>
              <p class="text-text-light mb-3">
                Vanaf &euro;5/maand. Elke euro wordt sadaqah jariyah.
              </p>
              <p class="text-text-light mb-4">
                Dit cre&euml;ert een stabiele, voorspelbare inkomstenstroom.
              </p>
              <span class="badge badge-growth">Binnenkort — wachtlijst open</span>
            </div>
          </div>
        </div>
        <!-- Connector -->
        <div class="flex justify-center">
          <div class="w-0.5 h-8 bg-capital-15"></div>
        </div>
      </div>

      <!-- Fase 3 -->
      <div class="relative mb-2">
        <div class="card card-capital fade-up delay-2">
          <div class="flex items-start gap-5">
            <div class="step-number step-number-capital shrink-0" style="margin: 0;">3</div>
            <div class="flex-1">
              <h3 class="text-xl mb-3">Op termijn: duurzame inkomsten voor de gemeenschap</h3>
              <p class="text-text-light mb-3">
                Vending machines op strategische locaties (moskee&euml;n, sportclubs, winkels).
              </p>
              <p class="text-text-light mb-3">
                Wij beheren alles. De locatie ontvangt 25% commissie. De rest bouwt het waqf-kapitaal.
              </p>
              <p class="text-text-light mb-4">
                Elke machine wordt een doorlopende bron van sadaqah jariyah.
              </p>
              <span class="badge badge-growth">Binnenkort — eerste machine in voorbereiding</span>
            </div>
          </div>
        </div>
        <!-- Connector -->
        <div class="flex justify-center">
          <div class="w-0.5 h-8 bg-gold-10"></div>
        </div>
      </div>

      <!-- Fase 4 -->
      <div class="relative">
        <div class="card card-gold fade-up delay-3">
          <div class="flex items-start gap-5">
            <div class="step-number step-number-growth shrink-0" style="margin: 0; font-size: 28px;">&infin;</div>
            <div class="flex-1">
              <h3 class="text-xl mb-3">Ons einddoel: een waqf dat voor altijd geeft</h3>
              <p class="text-text-light mb-3">
                Met het gespaarde kapitaal kopen we fysiek vastgoed: garageboxen, handelspanden, gebouwen.
              </p>
              <p class="text-text-light mb-3">
                De huurinkomsten maken het waqf volledig zelfvoorzienend.
              </p>
              <p class="text-text-light mb-4">
                Geen afhankelijkheid van donaties. Geen campagnes. Alleen stabiele, eeuwige inkomsten die de gemeenschap dienen.
              </p>
              <span class="badge badge-zakat">Toekomst — ons einddoel</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- LOKALE FOCUS -->
  <section class="section">
    <div class="container">
      <h2 class="text-center mb-4 fade-up">Eerst rond de kerktoren</h2>
      <p class="text-center text-lg mb-12 max-w-[700px] mx-auto fade-up delay-1 text-text-light">
        We beginnen niet in het buitenland. We beginnen HIER. In Belgi&euml;. Bij jouw moskee, jouw buurt, jouw stad. Pas wanneer ons lokale fundament sterk staat, kijken we verder.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="card card-capital text-center fade-up delay-1">
          <div class="w-16 h-16 mx-auto mb-4 rounded-full flex items-center justify-center overflow-hidden" style="background: linear-gradient(135deg, rgba(27,94,63,0.15), rgba(46,92,138,0.1));">
            <svg class="w-8 h-8 text-capital" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205 3 1m1.5.5-1.5-.5M6.75 7.364V3h-3v18m3-13.636 10.5-3.819" />
            </svg>
          </div>
          <h3 class="text-lg mb-2">Belgische moskee&euml;n</h3>
          <p class="text-sm text-text-light">We bouwen websites voor moskee&euml;n in Gent, Antwerpen, Brussel</p>
        </div>
        <div class="card card-capital text-center fade-up delay-2">
          <div class="w-16 h-16 mx-auto mb-4 rounded-full flex items-center justify-center overflow-hidden" style="background: linear-gradient(135deg, rgba(27,94,63,0.15), rgba(201,169,97,0.1));">
            <svg class="w-8 h-8 text-capital" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <h3 class="text-lg mb-2">Belgische gemeenschap</h3>
          <p class="text-sm text-text-light">E-books en Korans voor moslims en ge&iuml;nteresseerden in Belgi&euml;</p>
        </div>
        <div class="card card-capital text-center fade-up delay-3">
          <div class="w-16 h-16 mx-auto mb-4 rounded-full flex items-center justify-center overflow-hidden" style="background: linear-gradient(135deg, rgba(46,92,138,0.15), rgba(27,94,63,0.1));">
            <svg class="w-8 h-8 text-clarity" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21" />
            </svg>
          </div>
          <h3 class="text-lg mb-2">Belgisch vastgoed</h3>
          <p class="text-sm text-text-light">Onze eerste investeringen worden in Belgi&euml; gedaan</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WAT MAAKT DIT ANDERS -->
  <section class="section" style="background: white;">
    <div class="container-content">
      <h2 class="text-center mb-4 fade-up">Meer dan een gift. Een blijvend goed werk.</h2>
      <p class="text-lg mb-8 max-w-[700px] mx-auto text-center fade-up delay-1 text-text-light">
        De meeste islamitische organisaties vragen elk jaar opnieuw om donaties. Wij bouwen een waqf dat na verloop van tijd zelf genoeg genereert om de gemeenschap te dienen. Dat is de essentie: iets dat je &eacute;&eacute;n keer geeft, en dat voor altijd werkt.
      </p>
      <div class="callout callout-gold fade-up delay-2">
        <p class="font-heading font-bold text-lg text-capital">
          Een waqf is geen gift. Het is een INVESTERING in de eeuwigheid.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-lg bg-capital-dark">
    <div class="container text-center max-w-[700px]">
      <p class="display-quote mb-8 fade-up" style="color: rgba(255,255,255,0.9); font-style: italic;">
        "De beste tijd om een boom te planten was 20 jaar geleden. De op-een-na beste tijd is nu."
      </p>
      <p class="fade-up delay-1 text-lg mb-10" style="color: rgba(255,255,255,0.7);">Wacht niet. Bouw mee.</p>
      <div class="flex gap-4 justify-center flex-wrap fade-up delay-2">
        <a href="/de-bouwers" class="btn btn-gold">Word Bouwer</a>
        <a href="/wat-we-doen" class="btn btn-outline-white">Bekijk onze projecten</a>
      </div>
    </div>
  </section>

</Layout>
