---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Gratis Koran — Ummah.be Waqf" description="Vraag een gratis Nederlandstalige Koran aan. Geen voorwaarden, geen kosten. Sadaqah jariyah van Ummah.be Waqf.">

  <!-- HERO -->
  <section class="section bg-capital">
    <div class="container text-center max-w-[700px]">
      <h1 class="mb-4 fade-up text-white">Gratis Koran</h1>
      <p class="text-lg md:text-xl text-white/80 font-semibold fade-up delay-1">Benieuwd naar de Koran? Wij sturen er eentje. Gratis. Geen verplichtingen.</p>
    </div>
  </section>

  <!-- WAAROM -->
  <section class="section">
    <div class="container-narrow">
      <div class="card card-static fade-up">
        <p class="text-base text-text mb-6">
          De Koran is het meest gelezen boek ter wereld. Of u nu moslim bent, nieuwsgierig, of op zoek naar antwoorden — iedereen verdient toegang tot dit boek.
        </p>
        <blockquote class="blockquote-gold pl-4 mb-4 font-heading italic text-lg">
          "Wanneer een mens sterft, stoppen al zijn daden behalve drie: doorlopende liefdadigheid, kennis waar anderen profijt van hebben, en een vroom kind dat voor hem bidt."
        </blockquote>
        <p class="text-sm text-text-light mb-6">— Sahih Muslim 1631</p>
        <p class="text-base text-text">
          Wij sturen u een Nederlandstalige Koran met Arabische tekst. Volledig gratis, inclusief verzending.
        </p>
      </div>
    </div>
  </section>

  <!-- WAT U ONTVANGT -->
  <section class="section" style="background: white;">
    <div class="container">
      <h2 class="text-center mb-12 fade-up">Wat u ontvangt</h2>
      <div class="max-w-[500px] mx-auto">
        <div class="card card-static fade-up delay-1">
          <!-- Book cover placeholder -->
          <div class="bg-capital rounded-lg mb-6 flex items-center justify-center p-8" style="min-height: 220px;">
            <div class="text-center">
              <p class="font-arabic text-white/60 text-lg mb-2">القرآن الكريم</p>
              <p class="font-heading font-bold text-xl text-white leading-tight">De Heilige Koran</p>
              <p class="text-white/70 text-sm mt-2">Arabisch &mdash; Nederlands</p>
            </div>
          </div>

          <!-- Details -->
          <div class="space-y-3 mb-6">
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-capital shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <p class="text-base text-text">Arabisch + Nederlandse vertaling</p>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-capital shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <p class="text-base text-text">Inclusief begeleidende brief</p>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-capital shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <p class="text-base text-text">Gratis verzending binnen België</p>
            </div>
          </div>

          <!-- Badge -->
          <div class="text-center">
            <span class="badge badge-sacred">100% gratis — sadaqah jariyah</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- VOOR WIE -->
  <section class="section">
    <div class="container">
      <h2 class="text-center mb-12 fade-up">Voor wie is dit?</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Card 1: Nieuwsgierig -->
        <div class="card fade-up delay-1 text-center">
          <div class="w-14 h-14 rounded-full bg-capital-10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-capital" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
            </svg>
          </div>
          <h3 class="text-lg mb-3">Nieuwsgierig?</h3>
          <p class="text-sm text-text-light">Voor iedereen die de Koran wil lezen, ongeacht achtergrond.</p>
        </div>

        <!-- Card 2: Nieuwe moslim -->
        <div class="card fade-up delay-2 text-center">
          <div class="w-14 h-14 rounded-full bg-capital-10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-capital" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <h3 class="text-lg mb-3">Nieuwe moslim?</h3>
          <p class="text-sm text-text-light">Een eigen Koran is een waardevol begin van uw reis.</p>
        </div>

        <!-- Card 3: Cadeau -->
        <div class="card fade-up delay-3 text-center">
          <div class="w-14 h-14 rounded-full bg-capital-10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-capital" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 11.25v8.25a1.5 1.5 0 01-1.5 1.5H5.25a1.5 1.5 0 01-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 109.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1114.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
            </svg>
          </div>
          <h3 class="text-lg mb-3">Cadeau?</h3>
          <p class="text-sm text-text-light">Geef een Koran cadeau aan iemand die geïnteresseerd is.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- AANVRAAGFORMULIER -->
  <section class="section" style="background: white;" id="aanvraag">
    <div class="container-narrow">
      <div class="text-center mb-10 fade-up">
        <h2 class="mb-4">Vraag uw gratis Koran aan</h2>
        <p class="text-lg text-text-light">Eén Koran per huishouden. Verzending binnen België.</p>
      </div>

      <form id="koran-form" class="space-y-5 fade-up delay-1" novalidate>
        <!-- Naam -->
        <div>
          <label for="naam" class="form-label">Volledige naam</label>
          <input type="text" id="naam" name="naam" required autocomplete="name" class="input" placeholder="Uw volledige naam" />
        </div>

        <!-- Email -->
        <div>
          <label for="email" class="form-label">E-mail</label>
          <input type="email" id="email" name="email" required autocomplete="email" class="input" placeholder="uw@email.be" />
        </div>

        <!-- Straat -->
        <div>
          <label for="straat" class="form-label">Straat + huisnummer</label>
          <input type="text" id="straat" name="straat" required autocomplete="street-address" class="input" placeholder="Kerkstraat 12" />
        </div>

        <!-- Postcode + Stad -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="postcode" class="form-label">Postcode</label>
            <input type="text" id="postcode" name="postcode" required autocomplete="postal-code" class="input" placeholder="9000" />
          </div>
          <div>
            <label for="stad" class="form-label">Stad</label>
            <input type="text" id="stad" name="stad" required autocomplete="address-level2" class="input" placeholder="Gent" />
          </div>
        </div>

        <!-- Reden -->
        <div>
          <label for="reden" class="form-label">Reden</label>
          <select id="reden" name="reden" class="input">
            <option value="nieuwsgierig">Ik ben nieuwsgierig</option>
            <option value="nieuwe-moslim">Ik ben een nieuwe moslim</option>
            <option value="cadeau">Ik wil het als cadeau geven</option>
            <option value="anders">Anders</option>
          </select>
        </div>

        <!-- Opmerkingen -->
        <div>
          <label for="opmerkingen" class="form-label">Opmerkingen <span class="font-normal normal-case text-text-light">(optioneel)</span></label>
          <textarea id="opmerkingen" name="opmerkingen" rows="3" class="input" placeholder="Bijv. 'voor mijn studie' of 'als cadeau voor een vriend'"></textarea>
        </div>

        <!-- Privacy checkbox -->
        <div class="flex items-start gap-3">
          <input type="checkbox" id="privacy" name="privacy" required class="checkbox-touch mt-0.5" />
          <label for="privacy" class="text-sm text-text-light cursor-pointer">
            Ik ga akkoord met de <a href="/privacy" class="text-capital font-semibold underline">privacyverklaring</a>. Mijn gegevens worden enkel gebruikt voor de verzending.
          </label>
        </div>

        <!-- Submit -->
        <button type="submit" class="btn btn-capital w-full text-center">Koran aanvragen</button>

        <!-- Form message -->
        <div id="koran-form-message" class="form-message" role="status" aria-live="polite"></div>
      </form>
    </div>
  </section>

  <!-- SPONSOR EEN KORAN -->
  <section class="section">
    <div class="container text-center max-w-[600px]">
      <h2 class="mb-4 fade-up">Sponsor een Koran</h2>
      <p class="text-lg text-text-light mb-6 fade-up delay-1">
        Voor €15 sponsort u een Koran voor iemand die erom vraagt. Dat is sadaqah jariyah — voor u én voor de ontvanger.
      </p>
      <div class="mb-8 fade-up delay-2">
        <span class="badge badge-sacred">€15 per Koran — kennis die eeuwig doorgeeft</span>
      </div>
      <a href="/steun-ons" class="btn btn-capital fade-up delay-3">Sponsor een Koran</a>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-lg bg-capital-dark">
    <div class="container text-center max-w-[700px]">
      <p class="display-quote text-white/90 mb-6 fade-up">
        "Wie een weg bewandelt om kennis te zoeken, voor hem maakt Allah de weg naar het Paradijs gemakkelijk."
      </p>
      <p class="text-white/60 text-sm mb-10 fade-up delay-1">— Sahih Muslim</p>
      <a href="#aanvraag" class="btn btn-gold fade-up delay-2">Vraag uw gratis Koran aan</a>
    </div>
  </section>

</Layout>

<script>
  // Koran request form handler
  (() => {
    const form = document.getElementById('koran-form') as HTMLFormElement | null;
    const messageEl = document.getElementById('koran-form-message');
    if (!form || !messageEl) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Reset message
      messageEl.className = 'form-message';
      messageEl.textContent = '';

      // Validate required fields
      const naam = (form.querySelector('#naam') as HTMLInputElement).value.trim();
      const email = (form.querySelector('#email') as HTMLInputElement).value.trim();
      const straat = (form.querySelector('#straat') as HTMLInputElement).value.trim();
      const postcode = (form.querySelector('#postcode') as HTMLInputElement).value.trim();
      const stad = (form.querySelector('#stad') as HTMLInputElement).value.trim();
      const privacy = (form.querySelector('#privacy') as HTMLInputElement).checked;

      if (!naam || !email || !straat || !postcode || !stad) {
        messageEl.textContent = 'Vul alle verplichte velden in.';
        messageEl.className = 'form-message visible error';
        return;
      }

      if (!privacy) {
        messageEl.textContent = 'U dient akkoord te gaan met de privacyverklaring.';
        messageEl.className = 'form-message visible error';
        return;
      }

      // Email validation
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(email)) {
        messageEl.textContent = 'Vul een geldig e-mailadres in.';
        messageEl.className = 'form-message visible error';
        return;
      }

      // Show loading state
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      submitBtn.classList.add('loading');
      submitBtn.textContent = 'Verzenden...';

      // Simulate form submission (replace with actual API endpoint)
      try {
        await new Promise(resolve => setTimeout(resolve, 1200));

        // Success
        messageEl.textContent = 'Uw aanvraag is ontvangen! Wij verzenden uw Koran zo snel mogelijk. Moge het u zegenen.';
        messageEl.className = 'form-message visible success';
        form.reset();
      } catch {
        messageEl.textContent = 'Er ging iets mis. Probeer het later opnieuw of neem contact met ons op.';
        messageEl.className = 'form-message visible error';
      } finally {
        submitBtn.classList.remove('loading');
        submitBtn.textContent = 'Koran aanvragen';
      }
    });
  })();
</script>
