---
import Layout from '../layouts/Layout.astro';
import { fetchHomePage, fetchWaqfConfig } from '../lib/sanity';

const home = await fetchHomePage();
const waqf = await fetchWaqfConfig();

const heroTitle = home?.heroTitle || 'Ummah.be Waqf';
const heroSubtitle = home?.heroSubtitle || 'Een gift die nooit verloren gaat.\nVoor Allah. Voor de gemeenschap.\nVoor altijd.';
const heroDescription = home?.heroDescription || 'Een waqf is een oude islamitische traditie: je schenkt iets — geld, een huis, een stuk grond — en het blijft voor altijd bestaan. Elke maand geven de vruchten ervan iets terug aan onze gemeenschap. Dit noemen we sadaqah jariyah: doorlopende liefdadigheid die 1400 jaar teruggaat tot de Profeet ﷺ en zijn metgezellen.';
const btn1Label = home?.heroButtonPrimaryLabel || 'Draag bij aan Kapitaal';
const btn1Link = home?.heroButtonPrimaryLink || '/steun-ons';
const btn2Label = home?.heroButtonSecondaryLabel || "Steun Programma's Deze Maand";
const btn2Link = home?.heroButtonSecondaryLink || '/steun-ons';
const showBismillah = home?.bismillah !== false;
const waqfUitlegTitle = home?.waqfUitlegTitle || 'Wat is een Waqf?';
const waqfUitlegText = home?.waqfUitlegText || 'Een waqf is een eeuwige gift.';
const minWaqf = waqf?.minimumWaqfBijdrage || 1000;
const rendement = waqf?.verwachtRendement || 5;
const jaarlijkseOpbrengst = Math.round(minWaqf * rendement / 100);
---

<Layout title={`${heroTitle} — Kapitaal is heilig`} description={heroDescription}>

  <!-- HERO — Editorial luxury: typography-led, minimal decoration -->
  <section class="relative overflow-hidden" style="background: var(--color-peace); min-height: 640px;">
    <div class="container flex items-center justify-center text-center" style="min-height: 640px;">
      <div class="max-w-[720px] fade-up">
        {showBismillah && (
          <p class="text-2xl md:text-4xl mb-8 font-arabic" style="color: var(--color-capital);" lang="ar" dir="rtl">
            بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ
          </p>
        )}
        <h1 class="mb-8 text-capital" style="font-size: clamp(36px, 5.5vw, 56px);">{heroTitle}</h1>
        <p class="text-lg md:text-xl mb-8 leading-relaxed whitespace-pre-line text-clarity font-semibold">{heroSubtitle}</p>
        <p class="text-base mb-12 max-w-[600px] mx-auto text-text-light">{heroDescription}</p>
        <div class="flex gap-4 justify-center flex-wrap">
          <a href={btn1Link} class="btn btn-capital">{btn1Label}</a>
          <a href="#hoe-het-werkt" class="btn btn-outline">Hoe werkt het?</a>
        </div>
        <a href="/wat-is-een-waqf" class="inline-block mt-8 text-sm font-medium no-underline link-arrow text-capital">
          Wat is een waqf? Lees de uitleg
        </a>
      </div>
    </div>
    <!-- Subtle gold accent line -->
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-24 h-px" style="background: var(--color-gold);"></div>
  </section>

  <!-- HOE JE GIFT WERKT -->
  <section id="hoe-het-werkt" class="section" style="background: white;">
    <div class="container">
      <h2 class="text-center mb-4 fade-up">Hoe werkt jouw gift?</h2>
      <p class="text-center text-lg mb-12 max-w-[700px] mx-auto fade-up delay-1" style="color: var(--color-text-light);">
        Een eenvoudig voorbeeld — van jouw bijdrage naar blijvende impact.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="card card-capital text-center fade-up delay-1 step-connector">
          <div class="step-number step-number-capital">1</div>
          <h3 class="text-lg mb-2">€{minWaqf.toLocaleString('nl-BE')} Bijdrage</h3>
          <p class="text-sm" style="color: var(--color-text-light);">Jouw gift wordt toegevoegd aan het waqf-kapitaal</p>
        </div>
        <div class="card card-capital text-center fade-up delay-2 step-connector">
          <div class="step-number step-number-capital">2</div>
          <h3 class="text-lg mb-2">Onschendbaar</h3>
          <p class="text-sm" style="color: var(--color-text-light);">Het kapitaal blijft juridisch vastgelegd en wordt nooit uitgegeven</p>
        </div>
        <div class="card card-capital text-center fade-up delay-3 step-connector">
          <div class="step-number step-number-capital">3</div>
          <h3 class="text-lg mb-2">~€{jaarlijkseOpbrengst}/jaar*</h3>
          <p class="text-sm" style="color: var(--color-text-light);">Verwacht rendement ({rendement}%, niet gegarandeerd)</p>
        </div>
        <div class="card card-growth text-center fade-up delay-4 step-connector">
          <div class="step-number step-number-growth">&#10003;</div>
          <h3 class="text-lg mb-2">Mentorschap & E-books</h3>
          <p class="text-sm" style="color: var(--color-text-light);">Programma's dienen moslims</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WIE HOUDT TOEZICHT -->
  <section class="section">
    <div class="container">
      <h2 class="text-center mb-4 fade-up">Wie houdt toezicht?</h2>
      <p class="text-center text-lg mb-12 max-w-[700px] mx-auto fade-up delay-1" style="color: var(--color-text-light);">
        Vertrouwen verdien je niet met mooie woorden, maar met duidelijke structuren. Vier lagen van toezicht houden dit waqf eerlijk en islamitisch correct.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="card card-capital text-center fade-up delay-1">
          <div class="w-16 h-16 mx-auto mb-4 rounded-full flex items-center justify-center overflow-hidden" style="background: linear-gradient(135deg, rgba(27,94,63,0.15), rgba(201,169,97,0.1));">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="color: var(--color-capital);">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <h3 class="text-lg mb-3">De Trustee</h3>
          <p class="text-sm" style="color: var(--color-text-light);">
            Een onafhankelijke beheerder (<em>mutawalli</em>) die het kapitaal bewaart en juridisch aansprakelijk is onder Belgisch recht.
          </p>
        </div>
        <div class="card card-capital text-center fade-up delay-2">
          <div class="w-16 h-16 mx-auto mb-4 rounded-full flex items-center justify-center overflow-hidden" style="background: linear-gradient(135deg, rgba(27,94,63,0.15), rgba(46,92,138,0.1));">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="color: var(--color-capital);">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <h3 class="text-lg mb-3">Shariah Raad</h3>
          <p class="text-sm" style="color: var(--color-text-light);">
            Drie islamitische geleerden toetsen of alles — investeringen, uitgaven, beslissingen — shariah-conform blijft.
          </p>
        </div>
        <div class="card card-capital text-center fade-up delay-3">
          <div class="w-16 h-16 mx-auto mb-4 rounded-full flex items-center justify-center overflow-hidden" style="background: linear-gradient(135deg, rgba(46,92,138,0.15), rgba(27,94,63,0.1));">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="color: var(--color-clarity);">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0012 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 01-2.031.352 5.988 5.988 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 01-2.031.352 5.989 5.989 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971z" />
            </svg>
          </div>
          <h3 class="text-lg mb-3">Belgisch Recht</h3>
          <p class="text-sm" style="color: var(--color-text-light);">
            Als erkende VZW vallen wij onder Belgische wetgeving. Boekhouding, jaarrekening, audit — alles volgens de regels.
          </p>
        </div>
        <div class="card card-capital text-center fade-up delay-4">
          <div class="w-16 h-16 mx-auto mb-4 rounded-full flex items-center justify-center overflow-hidden" style="background: linear-gradient(135deg, rgba(74,124,89,0.15), rgba(27,94,63,0.1));">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="color: var(--color-growth);">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-lg mb-3">Jij</h3>
          <p class="text-sm" style="color: var(--color-text-light);">
            Maandelijkse <em>hisab</em> (financieel rapport) zodat je elke euro kunt volgen. Transparantie is geen luxe, het is onze belofte.
          </p>
        </div>
      </div>
      <div class="text-center mt-10 fade-up">
        <a href="/governance" class="btn btn-outline">Meer over toezicht &amp; bestuur →</a>
      </div>
    </div>
  </section>

  <!-- VERHALEN TEASER -->
  <section class="section" style="background: var(--color-peace);">
    <div class="container max-w-[900px]">
      <div class="text-center mb-12">
        <h2 class="mb-4 fade-up"><span class="counter-animate" aria-label="1400"></span> jaar aan bewijs</h2>
        <p class="text-lg max-w-[700px] mx-auto fade-up delay-1" style="color: var(--color-text-light);">
          Een waqf hoeft niet bewezen te worden — de geschiedenis deed dat al.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="card card-capital fade-up delay-1">
          <div class="w-12 h-12 rounded-full mb-3 flex items-center justify-center" style="background: linear-gradient(135deg, rgba(46,92,138,0.15), rgba(27,94,63,0.1));">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="color: var(--color-clarity);">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0z" />
            </svg>
          </div>
          <h3 class="text-lg mb-2">Biʾr Rumah</h3>
          <p class="text-sm" style="color: var(--color-text-light);">Uthman's waterput — 1400 jaar in gebruik.</p>
        </div>
        <div class="card card-capital fade-up delay-2">
          <div class="w-12 h-12 rounded-full mb-3 flex items-center justify-center" style="background: linear-gradient(135deg, rgba(27,94,63,0.15), rgba(201,169,97,0.1));">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="color: var(--color-capital);">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
          <h3 class="text-lg mb-2">Al-Azhar</h3>
          <p class="text-sm" style="color: var(--color-text-light);">Oudste universiteit ter wereld — 1050+ jaar waqf.</p>
        </div>
        <div class="card card-capital fade-up delay-3">
          <div class="w-12 h-12 rounded-full mb-3 flex items-center justify-center" style="background: linear-gradient(135deg, rgba(46,92,138,0.15), rgba(27,94,63,0.1));">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="color: var(--color-clarity);">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205 3 1m1.5.5-1.5-.5M6.75 7.364V3h-3v18m3-13.636 10.5-3.819" />
            </svg>
          </div>
          <h3 class="text-lg mb-2">Süleymaniye</h3>
          <p class="text-sm" style="color: var(--color-text-light);">Moskee, ziekenhuis, keukens — alles via waqf.</p>
        </div>
      </div>
      <div class="text-center mt-10 fade-up delay-4">
        <a href="/verhalen" class="btn btn-outline">Lees alle verhalen →</a>
      </div>
    </div>
  </section>

  <!-- CTA — Clean, typography-led -->
  <section class="section-lg" style="background: var(--color-capital-dark);">
    <div class="container text-center max-w-[700px]">
      <p class="display-quote text-white/90 mb-8 fade-up" style="font-style: italic;">
        "Sadaqah jariyah — een gift die nooit ophoudt met geven."
      </p>
      <p class="text-white/70 text-lg mb-10 fade-up delay-1">Jouw bijdrage werkt voor altijd.</p>
      <div class="flex gap-4 justify-center flex-wrap fade-up delay-2">
        <a href="/steun-ons" class="btn btn-gold">Draag bij aan Kapitaal</a>
        <a href="/steun-ons" class="btn btn-outline-white">Steun Programma's</a>
      </div>
    </div>
  </section>

</Layout>
