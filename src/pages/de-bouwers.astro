---
import Layout from '../layouts/Layout.astro';
---

<Layout title="De Bouwers — Ummah.be Waqf" description="Word Bouwer en draag maandelijks bij aan het waqf-kapitaal. Sadaqah jariyah die eeuwig de Ummah dient.">

  <!-- HERO -->
  <section class="section-lg bg-capital relative overflow-hidden">
    <div class="container text-center max-w-[700px]">
      <h1 class="text-white mb-6 fade-up" style="font-size: clamp(36px, 5.5vw, 56px);">De Bouwers</h1>
      <p class="text-xl md:text-2xl fade-up delay-1" style="color: rgba(255,255,255,0.8);">
        Bouw mee aan een waqf die eeuwig de Ummah dient
      </p>
    </div>
  </section>

  <!-- WAT IS EEN BOUWER? -->
  <section class="section">
    <div class="container">
      <h2 class="text-center mb-4 fade-up">Wat is een Bouwer?</h2>
      <p class="text-center text-lg mb-12 max-w-[700px] mx-auto fade-up delay-1 text-text-light">
        Een Bouwer draagt maandelijks bij aan het waqf-kapitaal. Jouw bijdrage is sadaqah jariyah — doorlopende liefdadigheid.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="card card-capital text-center fade-up delay-1 step-connector">
          <div class="step-number step-number-capital">1</div>
          <h3 class="text-lg mb-2">Jij draagt bij</h3>
          <p class="text-sm text-text-light">Elke maand gaat jouw bijdrage naar het waqf-kapitaal</p>
        </div>
        <div class="card card-capital text-center fade-up delay-2 step-connector">
          <div class="step-number step-number-capital">2</div>
          <h3 class="text-lg mb-2">Kapitaal groeit</h3>
          <p class="text-sm text-text-light">Het kapitaal wordt halal belegd en groeit duurzaam</p>
        </div>
        <div class="card card-growth text-center fade-up delay-3 step-connector">
          <div class="step-number step-number-growth">3</div>
          <h3 class="text-lg mb-2">Ummah profiteert</h3>
          <p class="text-sm text-text-light">De opbrengsten financieren programma's voor de gemeenschap</p>
        </div>
      </div>
    </div>
  </section>

  <!-- HOE HET WERKT -->
  <section class="section" style="background: white;">
    <div class="container max-w-[800px]">
      <h2 class="text-center mb-4 fade-up">Hoe het werkt</h2>
      <p class="text-center text-lg mb-12 max-w-[700px] mx-auto fade-up delay-1 text-text-light">
        Eenvoudig, flexibel en transparant.
      </p>

      <div class="card card-capital text-center mb-8 fade-up delay-2">
        <p class="text-sm font-semibold uppercase tracking-wider mb-2 text-capital">Kernbedrag</p>
        <p class="font-heading font-bold text-capital" style="font-size: clamp(36px, 5vw, 56px);">€20<span class="text-text-light text-lg font-sans font-normal">/maand</span></p>
        <p class="text-text-light mt-2">Minder dan 70 cent per dag</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="card card-static fade-up delay-3">
          <h3 class="text-lg mb-2">Flexibel</h3>
          <p class="text-sm text-text-light">Kies zelf je bedrag: van €5 tot €100 per maand. Eenmalige bijdragen zijn ook welkom.</p>
        </div>
        <div class="card card-static fade-up delay-4">
          <h3 class="text-lg mb-2">Sadaqah Jariyah</h3>
          <p class="text-sm text-text-light">Jouw bijdrage is sadaqah jariyah — doorlopende liefdadigheid die waqf-kapitaal wordt na storting.</p>
        </div>
      </div>

      <div class="callout callout-gold fade-up">
        <p class="text-sm font-semibold text-text">Niet fiscaal aftrekbaar — wij zijn daar eerlijk over.</p>
      </div>
    </div>
  </section>

  <!-- FOUNDING BOUWERS -->
  <section class="section">
    <div class="container max-w-[800px] text-center">
      <span class="badge badge-sacred mb-6 fade-up">Exclusief</span>
      <h2 class="mb-4 fade-up delay-1">Founding Bouwers</h2>
      <p class="text-lg mb-8 max-w-[600px] mx-auto fade-up delay-2 text-text-light">
        De eerste 50 Bouwers worden Founding Bouwers — een bijzondere status voor wie er vanaf het begin bij is.
      </p>

      <div class="card card-gold text-center mb-8 fade-up delay-3">
        <p class="text-sm font-semibold uppercase tracking-wider mb-2 text-gold">Beschikbaar</p>
        <p class="font-heading font-bold text-capital" style="font-size: clamp(32px, 4vw, 48px);">50 <span class="text-text-light text-lg font-sans font-normal">van 50 plekken</span></p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-left">
        <div class="card card-static fade-up delay-1">
          <div class="circle-icon circle-icon-gold mb-4">&#9733;</div>
          <h3 class="text-base mb-2">Founders-pagina</h3>
          <p class="text-sm text-text-light">Jouw naam op de permanente founders-pagina van Ummah.be</p>
        </div>
        <div class="card card-static fade-up delay-2">
          <div class="circle-icon circle-icon-gold mb-4">&#9993;</div>
          <h3 class="text-base mb-2">Kwartaalrapport</h3>
          <p class="text-sm text-text-light">Exclusieve uitnodiging voor het kwartaalrapport met het bestuur</p>
        </div>
        <div class="card card-static fade-up delay-3">
          <div class="circle-icon circle-icon-gold mb-4">&#9670;</div>
          <h3 class="text-base mb-2">Founding Bouwer badge</h3>
          <p class="text-sm text-text-light">Een permanente "Founding Bouwer" status die je altijd behoudt</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PRE-LAUNCH WAITLIST -->
  <section id="waitlist" class="section" style="background: white;">
    <div class="container max-w-[600px]">
      <div class="text-center mb-8">
        <span class="badge badge-sacred mb-6 fade-up">Pre-launch — VZW in oprichting</span>
        <h2 class="mb-4 fade-up delay-1">Schrijf je in als Bouwer</h2>
        <p class="text-text-light fade-up delay-2">
          Betaling start zodra de VZW geregistreerd is. Schrijf je nu in als Bouwer.
        </p>
      </div>

      <form id="bouwer-form" class="card card-capital fade-up delay-3" novalidate>
        <div class="mb-6">
          <label for="naam" class="form-label">Naam</label>
          <input type="text" id="naam" name="naam" class="input" placeholder="Je volledige naam" required />
        </div>

        <div class="mb-6">
          <label for="email" class="form-label">E-mailadres</label>
          <input type="email" id="email" name="email" class="input" placeholder="jouw@email.be" required />
        </div>

        <div class="mb-6">
          <label class="form-label">Gewenst maandbedrag</label>
          <div class="flex flex-wrap gap-3">
            <label class="cursor-pointer">
              <input type="radio" name="bedrag" value="5" class="sr-only peer" />
              <span class="inline-block px-5 py-3 rounded-full border-2 border-border text-sm font-semibold transition-all peer-checked:bg-capital peer-checked:text-white peer-checked:border-capital hover:border-capital-light">€5</span>
            </label>
            <label class="cursor-pointer">
              <input type="radio" name="bedrag" value="10" class="sr-only peer" />
              <span class="inline-block px-5 py-3 rounded-full border-2 border-border text-sm font-semibold transition-all peer-checked:bg-capital peer-checked:text-white peer-checked:border-capital hover:border-capital-light">€10</span>
            </label>
            <label class="cursor-pointer">
              <input type="radio" name="bedrag" value="20" class="sr-only peer" checked />
              <span class="inline-block px-5 py-3 rounded-full border-2 border-border text-sm font-semibold transition-all peer-checked:bg-capital peer-checked:text-white peer-checked:border-capital hover:border-capital-light">€20</span>
            </label>
            <label class="cursor-pointer">
              <input type="radio" name="bedrag" value="50" class="sr-only peer" />
              <span class="inline-block px-5 py-3 rounded-full border-2 border-border text-sm font-semibold transition-all peer-checked:bg-capital peer-checked:text-white peer-checked:border-capital hover:border-capital-light">€50</span>
            </label>
            <label class="cursor-pointer">
              <input type="radio" name="bedrag" value="100" class="sr-only peer" />
              <span class="inline-block px-5 py-3 rounded-full border-2 border-border text-sm font-semibold transition-all peer-checked:bg-capital peer-checked:text-white peer-checked:border-capital hover:border-capital-light">€100</span>
            </label>
          </div>
        </div>

        <div class="mb-8">
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" id="privacy" name="privacy" class="checkbox-touch mt-0.5" required />
            <span class="text-sm text-text-light">Ik ga akkoord met het <a href="/privacy" class="text-capital font-semibold no-underline hover:underline">privacybeleid</a></span>
          </label>
        </div>

        <button type="submit" class="btn btn-capital w-full text-center">Schrijf me in als Bouwer</button>

        <div id="form-message" class="form-message mt-4" role="alert" aria-live="polite"></div>
      </form>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container max-w-[700px]">
      <h2 class="text-center mb-10 fade-up">Veelgestelde vragen</h2>

      <div class="space-y-4">
        <details class="card card-static fade-up delay-1">
          <summary class="faq-summary">Wanneer start de betaling?</summary>
          <div class="faq-content">
            <div>
              <p class="text-text-light text-sm mt-4">
                De betaling start pas na de officiële VZW-registratie. Tot die tijd verzamelen we inschrijvingen zonder enige betalingsverplichting.
              </p>
            </div>
          </div>
        </details>

        <details class="card card-static fade-up delay-2">
          <summary class="faq-summary">Is mijn bijdrage een waqf-donatie?</summary>
          <div class="faq-content">
            <div>
              <p class="text-text-light text-sm mt-4">
                Het is sadaqah jariyah — doorlopende liefdadigheid. Jouw maandelijkse bijdrage wordt waqf-kapitaal na storting. Het kapitaal blijft onschendbaar en alleen de opbrengsten worden besteed.
              </p>
            </div>
          </div>
        </details>

        <details class="card card-static fade-up delay-3">
          <summary class="faq-summary">Kan ik later stoppen?</summary>
          <div class="faq-content">
            <div>
              <p class="text-text-light text-sm mt-4">
                Ja, je kunt maandelijks opzeggen. Wat al gestort is blijft waqf-kapitaal (dat is het principe van waqf), maar je hebt geen verdere verplichting.
              </p>
            </div>
          </div>
        </details>

        <details class="card card-static fade-up delay-4">
          <summary class="faq-summary">Wat als jullie de 50 Founding Bouwers niet halen?</summary>
          <div class="faq-content">
            <div>
              <p class="text-text-light text-sm mt-4">
                We starten ook met minder. Het doel van 50 is een ambitie, geen voorwaarde. Elke Bouwer telt.
              </p>
            </div>
          </div>
        </details>

        <details class="card card-static fade-up">
          <summary class="faq-summary">Is het fiscaal aftrekbaar?</summary>
          <div class="faq-content">
            <div>
              <p class="text-text-light text-sm mt-4">
                Nee, niet op dit moment. We zijn transparant: bijdragen aan Ummah.be Waqf zijn momenteel niet fiscaal aftrekbaar. Dit kan in de toekomst veranderen.
              </p>
            </div>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-lg bg-capital-dark">
    <div class="container text-center max-w-[700px]">
      <p class="display-quote mb-8 fade-up" style="color: rgba(255,255,255,0.9); font-style: italic;">
        "Wanneer een mens sterft, stoppen zijn daden — behalve drie: sadaqah jariyah, kennis waar anderen baat bij hebben, en een rechtschapen kind dat voor hem smeekt."
      </p>
      <p class="fade-up delay-1 text-sm mb-10" style="color: rgba(255,255,255,0.6);">— Sahih Muslim 1631</p>
      <div class="fade-up delay-2">
        <a href="#waitlist" class="btn btn-gold">Word Bouwer</a>
      </div>
    </div>
  </section>

</Layout>

<script>
  (() => {
    const form = document.getElementById('bouwer-form') as HTMLFormElement;
    const message = document.getElementById('form-message') as HTMLElement;

    if (!form || !message) return;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const naam = (form.querySelector('#naam') as HTMLInputElement).value.trim();
      const email = (form.querySelector('#email') as HTMLInputElement).value.trim();
      const privacy = (form.querySelector('#privacy') as HTMLInputElement).checked;

      // Validation
      if (!naam || !email) {
        message.textContent = 'Vul alsjeblieft je naam en e-mailadres in.';
        message.className = 'form-message visible error';
        return;
      }

      if (!email.includes('@') || !email.includes('.')) {
        message.textContent = 'Vul een geldig e-mailadres in.';
        message.className = 'form-message visible error';
        return;
      }

      if (!privacy) {
        message.textContent = 'Je moet akkoord gaan met het privacybeleid.';
        message.className = 'form-message visible error';
        return;
      }

      // Simulate submission
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      submitBtn.classList.add('loading');
      submitBtn.disabled = true;

      setTimeout(() => {
        submitBtn.classList.remove('loading');
        submitBtn.disabled = false;
        form.reset();
        // Re-check the default radio
        const defaultRadio = form.querySelector('input[name="bedrag"][value="20"]') as HTMLInputElement;
        if (defaultRadio) defaultRadio.checked = true;

        message.textContent = 'Welkom, Bouwer! We nemen contact op zodra de VZW geregistreerd is.';
        message.className = 'form-message visible success';
      }, 1500);
    });
  })();
</script>
