---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Wat we doen — Ummah.be Waqf" description="Ummah.be dient de gemeenschap al actief — het waqf maakt het eeuwig. Ontdek onze projecten: De Bouwers, e-books, moskee websites en mentorschap.">

  <!-- HERO -->
  <section class="section" style="background: var(--color-capital);">
    <div class="container text-center">
      <h1 class="text-white mb-4 fade-up">Wat we doen</h1>
      <p class="text-white/80 text-lg fade-up delay-1">Ummah.be dient de gemeenschap al actief — het waqf maakt het eeuwig</p>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section">
    <div class="container-narrow text-center">
      <p class="text-base md:text-lg leading-relaxed fade-up text-text-light">
        Ummah.be is vandaag al actief: we bouwen gratis websites voor moskeeën, delen islamitische kennis via e-books en begeleiden jonge moslims. Het waqf-fonds maakt deze projecten eeuwig — zodat ze blijven bestaan, ook zonder donaties.
      </p>
    </div>
  </section>

  <!-- PROJECTS GRID -->
  <section class="section" style="background: white;">
    <div class="container">
      <!-- DIENSTEN -->
      <h2 class="text-center mb-4 fade-up">Diensten</h2>
      <p class="text-center text-text-light mb-10 fade-up delay-1">Wat we nu al doen voor de gemeenschap</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-[960px] mx-auto mb-20">

        <!-- Moskee Websites -->
        <div class="card fade-up delay-1">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background: linear-gradient(135deg, rgba(27,94,63,0.15), rgba(46,92,138,0.1));">
              <svg class="w-6 h-6 text-capital" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205l3 1m1.5.5l-1.5-.5M6.75 7.364V3h-3v18m3-13.636l10.5-3.819" />
              </svg>
            </div>
            <span class="badge badge-growth">Actief</span>
          </div>
          <h3 class="text-xl mb-3">Websites voor Moskee&euml;n</h3>
          <p class="text-sm mb-4 text-text-light">Wij bouwen en onderhouden professionele websites voor Belgische moskee&euml;n. Gratis voor de gemeenschap.</p>
          <a href="/moskeeen" class="btn btn-capital">Website aanvragen &rarr;</a>
        </div>

        <!-- Vending Machines -->
        <div class="card fade-up delay-2">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background: linear-gradient(135deg, rgba(74,124,89,0.15), rgba(201,169,97,0.1));">
              <svg class="w-6 h-6 text-growth" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
              </svg>
            </div>
            <span class="badge badge-zakat">Binnenkort</span>
          </div>
          <h3 class="text-xl mb-3">Vending Machines</h3>
          <p class="text-sm mb-4 text-text-light">Verdien 25% passief inkomen met een vending machine op uw locatie. Ethisch gescreend assortiment. Wij beheren alles.</p>
          <a href="/vending" class="btn btn-capital">Meer info &rarr;</a>
        </div>
      </div>

      <!-- KENNIS -->
      <h2 class="text-center mb-4 fade-up">Kennis</h2>
      <p class="text-center text-text-light mb-10 fade-up delay-1">Gratis kennis delen als sadaqah jariyah</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-[960px] mx-auto mb-20">

        <!-- E-books -->
        <div class="card fade-up delay-1">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background: linear-gradient(135deg, rgba(46,92,138,0.15), rgba(27,94,63,0.1));">
              <svg class="w-6 h-6 text-clarity" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
              </svg>
            </div>
            <span class="badge badge-growth">Actief</span>
          </div>
          <h3 class="text-xl mb-3">Gratis E-books</h3>
          <p class="text-sm mb-4 text-text-light">Islamitische kennis in het Nederlands — voor ge&iuml;nteresseerden, nieuwe moslims en de gemeenschap.</p>
          <a href="/e-books" class="btn btn-capital">Download gratis &rarr;</a>
        </div>

        <!-- Gratis Koran -->
        <div class="card fade-up delay-2">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background: linear-gradient(135deg, rgba(201,169,97,0.15), rgba(27,94,63,0.1));">
              <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
              </svg>
            </div>
            <span class="badge badge-growth">Actief</span>
          </div>
          <h3 class="text-xl mb-3">Gratis Koran</h3>
          <p class="text-sm mb-4 text-text-light">Ontvang een gratis Koran (Arabisch + Nederlands). Voor iedereen — geen voorwaarden.</p>
          <a href="/gratis-koran" class="btn btn-capital">Koran aanvragen &rarr;</a>
        </div>
      </div>

      <!-- COMMUNITY -->
      <h2 class="text-center mb-4 fade-up">Community</h2>
      <p class="text-center text-text-light mb-10 fade-up delay-1">Samen bouwen aan een eeuwig fonds</p>
      <div class="grid grid-cols-1 gap-6 max-w-[500px] mx-auto">

        <!-- De Bouwers -->
        <div class="card fade-up delay-1">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background: linear-gradient(135deg, rgba(27,94,63,0.15), rgba(201,169,97,0.1));">
              <svg class="w-6 h-6 text-capital" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
              </svg>
            </div>
            <span class="badge badge-zakat">Binnenkort</span>
          </div>
          <h3 class="text-xl mb-3">De Bouwers</h3>
          <p class="text-sm mb-4 text-text-light">Word onderdeel van de eerste groep die het waqf-kapitaal opbouwt. Maandelijkse sadaqah jariyah vanaf &euro;5.</p>
          <a href="/de-bouwers" class="btn btn-capital">Word Bouwer &rarr;</a>
        </div>

      </div>
    </div>
  </section>

  <!-- HOW IT ALL CONNECTS -->
  <section class="section">
    <div class="container-narrow text-center">
      <h2 class="mb-8 fade-up">Hoe het samenhangt</h2>
      <div class="card card-static mb-10 fade-up delay-1">
        <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-6 text-base font-semibold">
          <span class="text-clarity">E-books + Moskee websites</span>
          <span class="text-text-light">=</span>
          <span class="text-capital">wat we NU doen</span>
        </div>
        <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-6 text-base font-semibold mt-4">
          <span class="text-gold">De Bouwers</span>
          <span class="text-text-light">=</span>
          <span class="text-capital">wat het EEUWIG maakt</span>
        </div>
      </div>
      <blockquote class="blockquote-gold pl-6 py-4 text-left fade-up delay-2">
        <p class="display-quote" style="font-size: clamp(22px, 3.5vw, 36px);">
          Het waqf is niet het begin — het is de vereeuwiging van wat al bestaat.
        </p>
      </blockquote>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-lg bg-capital-dark">
    <div class="container text-center max-w-[700px]">
      <h2 class="text-white/90 mb-8 fade-up">Doe mee</h2>
      <div class="flex gap-4 justify-center flex-wrap fade-up delay-1">
        <a href="/de-bouwers" class="btn btn-gold">Word Bouwer</a>
        <a href="/e-books" class="btn btn-outline-white">Download een e-book</a>
      </div>
    </div>
  </section>

</Layout>
