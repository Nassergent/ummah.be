---
import Layout from '../layouts/Layout.astro';
import { fetchSettings, fetchTeamMembers } from '../lib/sanity';

const settings = await fetchSettings();
const directors = await fetchTeamMembers('director');
const nasser = directors[0];
---

<Layout title="Over Ons — Ummah.be Waqf" description="Wie zijn wij? Waarom bestaat dit waqf? Een eerlijk verhaal over de mensen achter Ummah.be Waqf.">

  <!-- HERO -->
  <section class="py-20" style="background: var(--color-capital);">
    <div class="container text-center max-w-[800px]">
      <h1 class="text-white mb-4 fade-up">Wie zijn wij?</h1>
      <p class="text-white/80 text-lg fade-up delay-1">
        Een eerlijk verhaal over waarom Ummah.be Waqf bestaat, en wie er achter staat.
      </p>
    </div>
  </section>

  <!-- HET VERHAAL -->
  <section class="section">
    <div class="container max-w-[750px]">
      <div class="fade-up">
        <h2 class="mb-6">Het verhaal achter Ummah.be</h2>
        <p class="text-lg leading-relaxed mb-4" style="color: var(--color-text);">
          Het idee van een Belgische waqf is niet in één dag geboren. Het kwam tijdens gesprekken met familie, vrienden en imams — mensen die graag iets blijvends wilden doen voor onze gemeenschap, maar niet wisten <em>hoe</em>.
        </p>
        <p class="text-lg leading-relaxed mb-4" style="color: var(--color-text);">
          We zagen rondom ons moslims die veel geld gaven aan goede doelen, maar na een jaar was die bijdrage al op. We zagen oudere mensen die nadachten over hun nalatenschap en niet wisten wat ze moesten doen met hun spaargeld of huis. We zagen dat de <em>waqf</em> — een 1400 jaar oude islamitische traditie — vandaag in België nauwelijks bestaat.
        </p>
        <p class="text-lg leading-relaxed mb-4" style="color: var(--color-text);">
          Dus besloten we er één te bouwen. Niet als een bedrijf, niet als liefdadigheid, maar als iets blijvends: een waqf die <strong>voor altijd</strong> de Belgische moslimgemeenschap dient. Waar het kapitaal onschendbaar blijft, en alleen de vruchten (de opbrengsten) elke maand iets teruggeven aan mentorschap, educatie en gemeenschap.
        </p>
        <p class="text-lg leading-relaxed" style="color: var(--color-text);">
          Dit is nog maar het begin. We bouwen langzaam en eerlijk. Zonder grote beloftes, zonder marketing-trucs. Alleen: <em>sadaqah jariyah — doorlopende liefdadigheid — voor de Ummah.</em>
        </p>
      </div>
    </div>
  </section>

  <!-- ONZE MISSIE -->
  <section class="section" style="background: white;">
    <div class="container max-w-[900px]">
      <h2 class="text-center mb-12 fade-up">Waarvoor staan wij?</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="card card-capital fade-up delay-1">
          <div class="w-14 h-14 rounded-full mb-4 flex items-center justify-center text-2xl" style="background: rgba(27,94,63,0.1);">🎯</div>
          <h3 class="text-lg mb-3">Onze missie</h3>
          <p class="text-sm" style="color: var(--color-text-light);">
            Een Belgische waqf bouwen waar moslims hun kapitaal kunnen schenken — wetende dat het voor altijd de gemeenschap zal dienen.
          </p>
        </div>
        <div class="card card-capital fade-up delay-2">
          <div class="w-14 h-14 rounded-full mb-4 flex items-center justify-center text-2xl" style="background: rgba(27,94,63,0.1);">👁️</div>
          <h3 class="text-lg mb-3">Onze visie</h3>
          <p class="text-sm" style="color: var(--color-text-light);">
            Een Belgische moslimgemeenschap waar elke generatie kan leren, groeien en anderen helpen — gedragen door een eeuwig en eerlijk waqf-fonds.
          </p>
        </div>
        <div class="card card-capital fade-up delay-3">
          <div class="w-14 h-14 rounded-full mb-4 flex items-center justify-center text-2xl" style="background: rgba(27,94,63,0.1);">🌱</div>
          <h3 class="text-lg mb-3">Onze waarden</h3>
          <p class="text-sm" style="color: var(--color-text-light);">
            Eerlijkheid voor alles. Transparantie in alles. Bescheidenheid in hoe we ons presenteren. Dienstbaarheid als enig doel.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- DE OPRICHTER -->
  <section class="section">
    <div class="container max-w-[850px]">
      <h2 class="text-center mb-12 fade-up">De oprichter</h2>

      <div class="card fade-up delay-1">
        <div class="flex flex-col md:flex-row gap-8 items-start">
          <div class="w-32 h-32 shrink-0 rounded-full overflow-hidden flex items-center justify-center" style="background: rgba(46,92,138,0.1);">
            <span class="text-5xl">👤</span>
          </div>
          <div class="flex-1">
            <h3 class="text-2xl mb-1">{nasser?.naam || 'Nasser'}</h3>
            <p class="text-sm mb-4" style="color: var(--color-clarity);">{nasser?.titel || 'Oprichter &amp; Uitvoerend Coördinator'}</p>

            {nasser?.bio ? (
              <p class="text-base leading-relaxed mb-4" style="color: var(--color-text);">{nasser.bio}</p>
            ) : (
              <>
                <p class="text-base leading-relaxed mb-4" style="color: var(--color-text);">
                  Belgisch-Marokkaanse ondernemer, technoloog en moslim. Na jaren van werken aan digitale platformen voor moskeeën en de gemeenschap, groeide de overtuiging dat we iets blijvends moesten bouwen — iets dat verder zou reiken dan een website of app.
                </p>
                <p class="text-base leading-relaxed mb-4" style="color: var(--color-text);">
                  Ummah.be Waqf is dat project. Niet als eigenaar, maar als dienaar. De waqf zelf is geen eigendom — het is een <em>amanah</em> (vertrouwen) dat gedragen wordt voor Allah en voor de gemeenschap die nog moet komen.
                </p>
              </>
            )}

            {nasser?.quote ? (
              <blockquote class="mt-6 pl-4 italic text-base" style="border-left: 3px solid var(--color-gold); color: var(--color-capital);">
                "{nasser.quote}"
              </blockquote>
            ) : (
              <blockquote class="mt-6 pl-4 italic text-base" style="border-left: 3px solid var(--color-gold); color: var(--color-capital);">
                "Ik ben geen eigenaar van dit waqf. Ik ben één van de eerste bouwers — samen met iedereen die meedoet. De waqf zelf hoort niemand toe behalve Allah, en ze dient alleen de Ummah."
              </blockquote>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WAAROM GELOVEN -->
  <section class="section" style="background: white;">
    <div class="container max-w-[800px]">
      <h2 class="text-center mb-4 fade-up">Waarom zou je ons vertrouwen?</h2>
      <p class="text-center text-lg mb-12 fade-up delay-1" style="color: var(--color-text-light);">
        Een eerlijk antwoord: je moet ons niet blind vertrouwen. Hier zijn de structuren die ons eerlijk houden.
      </p>

      <div class="space-y-4">
        <div class="card fade-up delay-1">
          <h3 class="text-lg mb-2">🛡️ Onafhankelijke Trustee</h3>
          <p class="text-sm" style="color: var(--color-text-light);">
            Het waqf-kapitaal wordt niet beheerd door de oprichter, maar door een onafhankelijke Trustee (mutawalli) die juridisch aansprakelijk is onder Belgisch recht. De Trustee heeft vetorecht over grote beslissingen.
          </p>
        </div>
        <div class="card fade-up delay-2">
          <h3 class="text-lg mb-2">📖 Shariah Advisory Board</h3>
          <p class="text-sm" style="color: var(--color-text-light);">
            Drie onafhankelijke islamitische geleerden toetsen alle investeringen, uitgaven en structurele beslissingen op shariah-conformiteit. Hun goedkeuring is vereist.
          </p>
        </div>
        <div class="card fade-up delay-3">
          <h3 class="text-lg mb-2">🧭 Belgisch VZW-recht</h3>
          <p class="text-sm" style="color: var(--color-text-light);">
            Ummah.be Waqf wordt opgericht als een Belgische VZW met erkende filantropische status. Dat betekent: boekhouding bij de Nationale Bank, publieke jaarrekeningen, en wettelijk toezicht.
          </p>
        </div>
        <div class="card fade-up delay-4">
          <h3 class="text-lg mb-2">👁️ Maandelijkse hisab</h3>
          <p class="text-sm" style="color: var(--color-text-light);">
            Elke maand publiceren we een volledig financieel rapport (hisab). Elke euro in, elke euro uit. Geen verborgen posten, geen samenvattingen.
          </p>
        </div>
      </div>

      <div class="text-center mt-10 fade-up">
        <a href="/governance" class="btn btn-outline">Lees meer over toezicht &amp; bestuur</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20" style="background: var(--color-capital);">
    <div class="container text-center max-w-[700px]">
      <h2 class="text-white mb-4 fade-up">Wil je meedoen aan dit verhaal?</h2>
      <p class="text-white/80 text-lg mb-8 fade-up delay-1">
        Een bijdrage, een vraag, of gewoon een gesprek — we zijn er.
      </p>
      <div class="flex gap-4 justify-center flex-wrap fade-up delay-2">
        <a href="/steun-ons" class="btn" style="background: var(--color-gold); color: var(--color-capital-dark);">Steun Ons</a>
        <a href="/contact" class="btn btn-outline" style="border-color: white; color: white;">Neem Contact Op</a>
      </div>
    </div>
  </section>

</Layout>
